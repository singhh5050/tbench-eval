[302.619087, "o", "\u001b[?2004h> "]
[302.619117, "o", "   ((equal? proc 'fread) (fread (car args)))\r\n\u001b[?2004l\r"]
[302.619139, "o", "\u001b[?2004h> "]
[302.619185, "o", "   ((equal? proc 'fdisplay) (fdisplay (car args) (cadr args)) #f)\r\n\u001b[?2004l\r"]
[302.619207, "o", "\u001b[?2004h> "]
[302.619252, "o", "   ((equal? proc 'fputchr) (fputchr (car args) (cadr args)) #f)\r\n\u001b[?2004l\r"]
[302.619273, "o", "\u001b[?2004h> "]
[302.619295, "o", "   (else\r\n\u001b[?2004l\r\u001b[?2004h> "]
[302.619315, "o", "    (display \"Unknown builtin: \")\r\n\u001b[?2004l\r"]
[302.619337, "o", "\u001b[?2004h> "]
[302.619358, "o", "    (display proc)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[302.61938, "o", "    (newline)\r\n\u001b[?2004l\r"]
[302.619401, "o", "\u001b[?2004h>     #f)))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[302.619421, "o", "\u001b[?2004h> "]
[302.619441, "o", "(define (apply-op op args)\r\n\u001b[?2004l\r\u001b[?2004h"]
[302.619462, "o", "> "]
[302.619484, "o", "  (if (null? args)\r\n\u001b[?2004l\r\u001b[?2004h>       0\r\n\u001b[?2004l\r"]
[302.619505, "o", "\u001b[?2004h> "]
[302.619543, "o", "      (let loop ((acc (car args)) (rest (cdr args)))\r\n\u001b[?2004l\r"]
[302.619565, "o", "\u001b[?2004h> "]
[302.619586, "o", "        (if (null? rest)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[302.619607, "o", "            acc\r\n\u001b[?2004l\r\u001b[?2004h"]
[302.619616, "o", "> "]
[302.619663, "o", "            (loop (op acc (car rest)) (cdr rest))))))\r\n"]
