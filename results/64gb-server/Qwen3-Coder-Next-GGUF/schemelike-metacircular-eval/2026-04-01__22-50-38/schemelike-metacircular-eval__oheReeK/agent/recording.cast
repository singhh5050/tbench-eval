[221.225509, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[221.225523, "o", "\u001b[?2004h> "]
[221.225557, "o", ";; Main: read file path and interpret\r\n\u001b[?2004l\r"]
[221.225571, "o", "\u001b[?2004h> "]
[221.225597, "o", "(let ((filepath (read-line)))\r\n\u001b[?2004l\r"]
[221.225612, "o", "\u001b[?2004h> "]
[221.225625, "o", "  (if filepath\r\n\u001b[?2004l\r"]
[221.225639, "o", "\u001b[?2004h> "]
