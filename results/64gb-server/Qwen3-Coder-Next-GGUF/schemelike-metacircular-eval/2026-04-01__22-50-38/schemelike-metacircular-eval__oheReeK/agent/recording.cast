[103.230067, "o", "> "]
[103.230161, "o", "                (eval (car (cdr (cdr cdr)))))))\r\n\u001b[?2004l\r"]
[103.230198, "o", "\u001b[?2004h> "]
[103.230256, "o", "       ((equal? car 'define)\r\n\u001b[?2004l\r"]
