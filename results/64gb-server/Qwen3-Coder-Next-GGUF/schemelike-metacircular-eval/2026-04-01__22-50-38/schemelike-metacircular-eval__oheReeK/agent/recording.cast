[302.615486, "o", "\u001b[?2004h> "]
[302.615529, "o", "              (body (car (cdr tail))))\r\n\u001b[?2004l\r"]
[302.615551, "o", "\u001b[?2004h> "]
[302.615571, "o", "          (if (pair? name)\r\n\u001b[?2004l\r\u001b[?2004h"]
[302.615593, "o", "> "]
[302.61565, "o", "              (env-define (car name) (eval (cons 'lambda (cons (cdr name) body))))\r\n\u001b[?2004l\r"]
[302.615682, "o", "\u001b[?2004h> "]
[302.615709, "o", "              (env-define name (eval body)))))\r\n\u001b[?2004l\r"]
[302.615731, "o", "\u001b[?2004h> "]
[302.615753, "o", "       ((equal? head 'set!)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[302.615804, "o", "        (env-set! (car tail) (eval (car (cdr tail)))))\r\n\u001b[?2004l\r"]
[302.615826, "o", "\u001b[?2004h> "]
[302.615846, "o", "       ((equal? head 'lambda)\r\n\u001b[?2004l\r\u001b[?2004h"]
[302.615867, "o", "> "]
[302.615895, "o", "        (list 'procedure (car tail) (cdr tail)))\r\n\u001b[?2004l\r"]
[302.615916, "o", "\u001b[?2004h> "]
[302.615938, "o", "       ((equal? head 'cond)\r\n\u001b[?2004l\r"]
[302.61596, "o", "\u001b[?2004h> "]
[302.615983, "o", "        (eval-cond tail))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[302.616002, "o", "       ((equal? head 'let)\r\n\u001b[?2004l\r"]
[302.616023, "o", "\u001b[?2004h> "]
[302.616045, "o", "        (eval-let tail))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[302.616073, "o", "       ((equal? head 'progn)\r\n\u001b[?2004l\r"]
[302.616094, "o", "\u001b[?2004h> "]
