[103.232627, "o", "\u001b[?2004h"]
[103.232642, "o", "> "]
[103.232674, "o", ";; Apply a procedure to arguments\r\n\u001b[?2004l\r"]
[103.232687, "o", "\u001b[?2004h"]
[103.232702, "o", "> "]
[103.232723, "o", "(define (apply proc args)\r\n\u001b[?2004l\r"]
[103.232738, "o", "\u001b[?2004h> "]
[103.232768, "o", "  (if (procedure? proc)\r\n\u001b[?2004l\r"]
[103.232783, "o", "\u001b[?2004h> "]
[103.232816, "o", "      (let ((params (car proc))\r\n"]
[103.232826, "o", "\u001b[?2004l\r"]
[103.232837, "o", "\u001b[?2004h> "]
[103.232872, "o", "            (body (car (cdr proc)))\r\n\u001b[?2004l\r"]
[103.232885, "o", "\u001b[?2004h"]
[103.232898, "o", "> "]
[103.232934, "o", "            (env (car (cdr (cdr proc)))))\r\n\u001b[?2004l\r"]
[103.232948, "o", "\u001b[?2004h> "]
[103.23298, "o", "        (let ((new-env env))\r\n\u001b[?2004l\r"]
[103.232994, "o", "\u001b[?2004h> "]
[103.233064, "o", "          (for-each (lambda (p a) (env-define new-env p a)) params args)\r\n\u001b[?2004l\r"]
[103.233076, "o", "\u001b[?2004h"]
[103.233089, "o", "> "]
[103.233125, "o", "          (eval-sequence body new-env)))\r\n\u001b[?2004l\r"]
[103.233141, "o", "\u001b[?2004h> "]
[103.233177, "o", "      (apply-builtin proc args)))\r\n\u001b[?2004l\r"]
[103.233192, "o", "\u001b[?2004h> \r\n"]
[103.233203, "o", "\u001b[?2004l\r"]
[103.233218, "o", "\u001b[?2004h> "]
[103.233239, "o", ";; Built-in procedures\r\n\u001b[?2004l\r"]
[103.233252, "o", "\u001b[?2004h"]
[103.233267, "o", "> "]
[103.233295, "o", "(define (apply-builtin proc args)\r\n\u001b[?2004l\r"]
[103.233308, "o", "\u001b[?2004h"]
[103.233322, "o", "> "]
[103.233338, "o", "  (cond\r\n\u001b[?2004l\r"]
[103.233349, "o", "\u001b[?2004h> "]
[103.233383, "o", "   ((equal? proc '+) (apply-op + args))\r\n\u001b[?2004l\r"]
[103.233397, "o", "\u001b[?2004h> "]
[103.233439, "o", "   ((equal? proc '-) (apply-op - args))\r\n\u001b[?2004l\r"]
[103.233451, "o", "\u001b[?2004h"]
[103.233462, "o", "> "]
[103.233498, "o", "   ((equal? proc '*) (apply-op * args))\r\n\u001b[?2004l\r"]
[103.233513, "o", "\u001b[?2004h> "]
[103.233554, "o", "   ((equal? proc '/) (apply-op / args))\r\n\u001b[?2004l\r"]
[103.233569, "o", "\u001b[?2004h> "]
[103.233612, "o", "   ((equal? proc '=) (apply-comp = args))\r\n\u001b[?2004l\r"]
[103.233625, "o", "\u001b[?2004h> "]
[103.233674, "o", "   ((equal? proc '<) (apply-comp < args))\r\n\u001b[?2004l\r"]
[103.233691, "o", "\u001b[?2004h> "]
[103.233733, "o", "   ((equal? proc '>) (apply-comp > args))\r\n\u001b[?2004l\r"]
[103.233748, "o", "\u001b[?2004h"]
[103.233762, "o", "> "]
[103.233799, "o", "   ((equal? proc '<=) (apply-comp <= args))\r\n\u001b[?2004l\r"]
[103.233808, "o", "\u001b[?2004h"]
[103.233823, "o", "> "]
[103.233861, "o", "   ((equal? proc '>=) (apply-comp >= args))\r\n\u001b[?2004l\r"]
[103.233876, "o", "\u001b[?2004h"]
[103.233887, "o", "> "]
[103.233923, "o", "   ((equal? proc 'car) (car (car args)))\r\n\u001b[?2004l\r"]
[103.233936, "o", "\u001b[?2004h"]
[103.233951, "o", "> "]
[103.233986, "o", "   ((equal? proc 'cdr) (cdr (car args)))\r\n\u001b[?2004l\r"]
[103.234, "o", "\u001b[?2004h"]
[103.234015, "o", "> "]
[103.23406, "o", "   ((equal? proc 'cons) (cons (car args) (cadr args)))\r\n\u001b[?2004l\r"]
[103.234074, "o", "\u001b[?2004h> "]
[103.234129, "o", "   ((equal? proc 'null?) (if (null? (car args)) #t #f))\r\n\u001b[?2004l\r"]
[103.234143, "o", "\u001b[?2004h> "]
[103.234211, "o", "   ((equal? proc 'equal?) (if (equal? (car args) (cadr args)) #t #f))\r\n\u001b[?2004l\r"]
[103.234226, "o", "\u001b[?2004h> "]
[103.234288, "o", "   ((equal? proc 'eq?) (if (eq? (car args) (cadr args)) #t #f))\r\n\u001b[?2004l\r"]
[103.234303, "o", "\u001b[?2004h> "]
[103.234358, "o", "   ((equal? proc 'pair?) (if (pair? (car args)) #t #f))\r\n\u001b[?2004l\r"]
[103.23437, "o", "\u001b[?2004h> "]
[103.234425, "o", "   ((equal? proc 'display) (display (car args)) #f)\r\n\u001b[?2004l\r"]
[103.234435, "o", "\u001b[?2004h"]
[103.234446, "o", "> "]
[103.23449, "o", "   ((equal? proc 'newline) (newline) #f)\r\n\u001b[?2004l\r"]
[103.234504, "o", "\u001b[?2004h> "]
[103.234539, "o", "   ((equal? proc 'read) (read))\r\n\u001b[?2004l\r"]
[103.234555, "o", "\u001b[?2004h"]
