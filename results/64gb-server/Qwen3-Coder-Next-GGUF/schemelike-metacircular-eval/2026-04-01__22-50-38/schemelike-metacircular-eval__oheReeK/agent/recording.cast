[103.22967, "o", "          (display name)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[103.229712, "o", "          (newline)\r\n\u001b[?2004l\r\u001b[?2004h>           #f))))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> (define (env-set! name value)\r\n\u001b[?2004l\r\u001b[?2004h>   (let ((cell (assoc name env)))\r\n\u001b[?2004l\r\u001b[?2004h>     (if cell\r\n\u001b[?2004l\r\u001b[?2004h>         (set-cdr! cell value)\r\n\u001b[?2004l\r\u001b[?2004h>         (begin\r\n\u001b[?2004l\r\u001b[?2004h>           (display \"Error: cannot set undefined variable \")\r\n\u001b[?2004l\r\u001b[?2004h>           (display name)\r\n\u001b[?2004l\r\u001b[?2004h>           (newline)\r\n\u001b[?2004l\r\u001b[?2004h>           #f))))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> ;; Evaluate a pair (procedure call or special form)\r\n\u001b[?2004l\r\u001b[?2004h> (define (eval-pair expr)\r\n\u001b[?2004l\r\u001b[?2004h>   (let ((car (car expr))\r\n\u001b[?2004l\r\u001b[?2004h>         (cdr (cdr expr)))\r\n\u001b[?2004l\r\u001b[?2004h>     (cond\r\n\u001b[?2004l\r\u001b[?2004h>      ((symbol? car)\r\n\u001b[?2004l\r\u001b[?2004h>       (cond\r\n\u001b[?2004l\r\u001b[?2004h>        ((equal? car 'quote)\r\n\u001b[?2004l\r\u001b[?2004h>         (car cdr))\r\n\u001b[?2004l\r\u001b[?2004h>        ((equal? car 'if)\r\n\u001b[?2004l\r\u001b[?2004h>         (if (eval (car cdr))\r\n\u001b[?2004l\r\u001b"]
[103.229742, "o", "[?2004h>             (eval (car (cdr cdr)))\r\n\u001b[?2004l\r\u001b[?2004h>             (if (null? (cdr (cdr cdr)))\r\n\u001b[?2004l\r\u001b[?2004h> "]
