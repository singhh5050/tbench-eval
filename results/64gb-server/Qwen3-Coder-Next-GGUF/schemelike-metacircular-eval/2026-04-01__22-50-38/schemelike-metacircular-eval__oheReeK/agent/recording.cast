[302.617833, "o", ";; Built-in procedures\r\n\u001b[?2004l\r"]
[302.617843, "o", "\u001b[?2004h> "]
[302.617874, "o", "(define (apply-builtin proc args)\r\n\u001b[?2004l\r"]
[302.617897, "o", "\u001b[?2004h> "]
[302.617919, "o", "  (cond\r\n\u001b[?2004l\r\u001b[?2004h> "]
[302.617942, "o", "   ((equal? proc '+) (apply-op + args))\r\n\u001b[?2004l\r"]
[302.617964, "o", "\u001b[?2004h> "]
[302.617993, "o", "   ((equal? proc '-) (apply-op - args))\r\n\u001b[?2004l\r"]
[302.618014, "o", "\u001b[?2004h> "]
[302.61804, "o", "   ((equal? proc '*) (apply-op * args))\r\n\u001b[?2004l\r"]
[302.618061, "o", "\u001b[?2004h> "]
[302.618087, "o", "   ((equal? proc '/) (apply-op / args))\r\n\u001b[?2004l\r"]
[302.618108, "o", "\u001b[?2004h> "]
[302.618135, "o", "   ((equal? proc '=) (apply-comp = args))\r\n\u001b[?2004l\r"]
[302.618157, "o", "\u001b[?2004h> "]
[302.618185, "o", "   ((equal? proc '<) (apply-comp < args))\r\n\u001b[?2004l\r"]
[302.618208, "o", "\u001b[?2004h> "]
[302.618232, "o", "   ((equal? proc '>) (apply-comp > args))\r\n\u001b[?2004l\r"]
[302.618256, "o", "\u001b[?2004h> "]
[302.618282, "o", "   ((equal? proc '<=) (apply-comp <= args))\r\n\u001b[?2004l\r"]
[302.618304, "o", "\u001b[?2004h> "]
[302.618332, "o", "   ((equal? proc '>=) (apply-comp >= args))\r\n\u001b[?2004l\r"]
[302.618354, "o", "\u001b[?2004h> "]
[302.61838, "o", "   ((equal? proc 'car) (car (car args)))\r\n\u001b[?2004l\r"]
[302.618402, "o", "\u001b[?2004h> "]
[302.618426, "o", "   ((equal? proc 'cdr) (cdr (car args)))\r\n\u001b[?2004l\r"]
[302.618447, "o", "\u001b[?2004h> "]
[302.618486, "o", "   ((equal? proc 'cons) (cons (car args) (cadr args)))\r\n\u001b[?2004l\r"]
[302.618506, "o", "\u001b[?2004h> "]
[302.618547, "o", "   ((equal? proc 'null?) (if (null? (car args)) #t #f))\r\n\u001b[?2004l\r"]
[302.61857, "o", "\u001b[?2004h> "]
[302.61862, "o", "   ((equal? proc 'equal?) (if (equal? (car args) (cadr args)) #t #f))\r\n\u001b[?2004l\r"]
[302.618642, "o", "\u001b[?2004h> "]
[302.61869, "o", "   ((equal? proc 'eq?) (if (eq? (car args) (cadr args)) #t #f))\r\n\u001b[?2004l\r"]
[302.618711, "o", "\u001b[?2004h> "]
[302.61875, "o", "   ((equal? proc 'pair?) (if (pair? (car args)) #t #f))\r\n\u001b[?2004l\r"]
[302.618771, "o", "\u001b[?2004h> "]
[302.618806, "o", "   ((equal? proc 'display) (display (car args)) #f)\r\n\u001b[?2004l\r"]
[302.618827, "o", "\u001b[?2004h> "]
[302.618853, "o", "   ((equal? proc 'newline) (newline) #f)\r\n\u001b[?2004l\r"]
[302.618876, "o", "\u001b[?2004h> "]
[302.618896, "o", "   ((equal? proc 'read) (read))\r\n\u001b[?2004l\r"]
[302.618917, "o", "\u001b[?2004h> "]
[302.618951, "o", "   ((equal? proc 'putchr) (fputchr 0 (car args)) #f)\r\n\u001b[?2004l\r"]
[302.618973, "o", "\u001b[?2004h> "]
[302.619013, "o", "   ((equal? proc 'fopen) (fopen (car args) (cadr args)))\r\n\u001b[?2004l\r"]
[302.619033, "o", "\u001b[?2004h> "]
