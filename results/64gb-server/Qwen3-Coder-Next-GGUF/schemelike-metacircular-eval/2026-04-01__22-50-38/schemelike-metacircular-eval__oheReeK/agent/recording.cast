[103.232351, "o", "> "]
[103.232377, "o", "      (let ((first (car exprs))\r\n\u001b[?2004l\r"]
[103.232391, "o", "\u001b[?2004h> "]
[103.232425, "o", "            (rest (cdr exprs)))\r\n\u001b[?2004l\r"]
[103.23244, "o", "\u001b[?2004h> "]
