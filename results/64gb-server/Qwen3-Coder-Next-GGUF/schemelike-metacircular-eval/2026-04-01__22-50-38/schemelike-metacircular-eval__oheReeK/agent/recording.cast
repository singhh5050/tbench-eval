[302.62051, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[302.620532, "o", ";; Continue reading and interpreting from stdin\r\n\u001b[?2004l\r"]
[302.620544, "o", "\u001b[?2004h> "]
[302.620555, "o", "(let loop ()\r\n\u001b[?2004l\r"]
[302.620566, "o", "\u001b[?2004h> "]
[302.620589, "o", "  (let ((expr (read)))\r\n\u001b[?2004l\r"]
