[221.225688, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[221.225702, "o", "\u001b[?2004h> "]
[221.225742, "o", ";; Continue reading and interpreting from stdin\r\n\u001b[?2004l\r"]
[221.225754, "o", "\u001b[?2004h> "]
[221.22577, "o", "(let loop ()\r\n\u001b[?2004l\r"]
[221.225783, "o", "\u001b[?2004h> "]
