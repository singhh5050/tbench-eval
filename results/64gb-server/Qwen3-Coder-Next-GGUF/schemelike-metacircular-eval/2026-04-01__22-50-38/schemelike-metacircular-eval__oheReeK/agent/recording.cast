[302.616306, "o", "\u001b[?2004h> "]
[302.616323, "o", "  (if (null? clauses)\r\n\u001b[?2004l\r"]
[302.616347, "o", "\u001b[?2004h>       #f\r\n\u001b[?2004l\r\u001b[?2004h> "]
[302.61638, "o", "      (let ((first (car clauses)))\r\n\u001b[?2004l\r"]
[302.616401, "o", "\u001b[?2004h> "]
[302.616419, "o", "        (let ((pred (car first))\r\n\u001b[?2004l\r"]
[302.616442, "o", "\u001b[?2004h> "]
[302.616461, "o", "              (body (cdr first)))\r\n\u001b[?2004l\r"]
[302.616482, "o", "\u001b[?2004h> "]
