[302.62013, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[302.620159, "o", "      (cons (f (car lst)) (map f (cdr lst)))))\r\n\u001b[?2004l\r"]
[302.620166, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[302.620169, "o", "\u001b[?2004h"]
[302.620173, "o", "> "]
[302.620197, "o", "(define (for-each f lst)\r\n\u001b[?2004l\r"]
