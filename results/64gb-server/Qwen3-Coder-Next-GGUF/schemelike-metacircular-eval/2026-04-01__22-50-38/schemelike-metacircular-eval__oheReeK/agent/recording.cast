[376.31911, "o", "                (fclose f)))))))\r\n\u001b[?2004l\r"]
[376.319122, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[376.319134, "o", "\u001b[?2004h> "]
[376.319172, "o", ";; The main eval function\r\n\u001b[?2004l\r"]
[376.319183, "o", "\u001b[?2004h> "]
[376.319211, "o", "(define (eval expr)\r\n\u001b[?2004l\r"]
[376.319223, "o", "\u001b[?2004h> "]
[376.319234, "o", "  (cond\r\n\u001b[?2004l\r"]
[376.319244, "o", "\u001b[?2004h> "]
[376.319281, "o", "   ((number? expr) expr)\r\n\u001b[?2004l\r"]
[376.319289, "o", "\u001b[?2004h> "]
[376.319329, "o", "   ((boolean? expr) expr)\r\n\u001b[?2004l\r"]
[376.319341, "o", "\u001b[?2004h> "]
[376.319377, "o", "   ((string? expr) expr)\r\n\u001b[?2004l\r"]
[376.319391, "o", "\u001b[?2004h> "]
[376.319437, "o", "   ((symbol? expr) (env-get expr))\r\n\u001b[?2004l\r"]
[376.319449, "o", "\u001b[?2004h> "]
[376.319472, "o", "   ((pair? expr)\r\n\u001b[?2004l\r"]
[376.319485, "o", "\u001b[?2004h> "]
[376.319516, "o", "    (eval-pair expr))\r\n\u001b[?2004l\r"]
[376.319529, "o", "\u001b[?2004h> "]
[376.319554, "o", "   (else expr)))\r\n\u001b[?2004l\r"]
[376.319565, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[376.319577, "o", "\u001b[?2004h> "]
[376.319609, "o", "(define (eval-pair p)\r\n\u001b[?2004l\r"]
[376.31962, "o", "\u001b[?2004h> "]
[376.319657, "o", "  (let ((head (car p))\r\n\u001b[?2004l\r"]
[376.319671, "o", "\u001b[?2004h> "]
[376.319703, "o", "        (tail (cdr p)))\r\n\u001b[?2004l\r"]
[376.319714, "o", "\u001b[?2004h> "]
[376.319731, "o", "    (cond\r\n\u001b[?2004l\r"]
[376.319742, "o", "\u001b[?2004h> "]
[376.319774, "o", "     ((symbol? head)\r\n\u001b[?2004l\r"]
[376.319785, "o", "\u001b[?2004h> "]
[376.319805, "o", "      (cond\r\n\u001b[?2004l\r"]
[376.319817, "o", "\u001b[?2004h> "]
[376.31986, "o", "       ((equal? head 'quote)\r\n\u001b[?2004l\r"]
[376.319872, "o", "\u001b[?2004h> "]
[376.3199, "o", "        (car tail))\r\n\u001b[?2004l\r"]
[376.319909, "o", "\u001b[?2004h> "]
[376.319946, "o", "       ((equal? head 'if)\r\n\u001b[?2004l\r"]
[376.319959, "o", "\u001b[?2004h> "]
[376.320002, "o", "        (if (eval (car tail))\r\n\u001b[?2004l\r"]
[376.320015, "o", "\u001b[?2004h> "]
[376.320063, "o", "            (eval (car (cdr tail)))\r\n\u001b[?2004l\r"]
[376.320075, "o", "\u001b[?2004h> "]
[376.320131, "o", "            (if (null? (cdr (cdr tail)))\r\n\u001b[?2004l\r"]
[376.320143, "o", "\u001b[?2004h> "]
[376.320172, "o", "                #f\r\n\u001b[?2004l\r"]
[376.320185, "o", "\u001b[?2004h> "]
[376.320253, "o", "                (eval (car (cdr (cdr tail)))))))\r\n\u001b[?2004l\r"]
[376.320265, "o", "\u001b[?2004h> "]
[376.320307, "o", "       ((equal? head 'define)\r\n\u001b[?2004l\r"]
[376.320319, "o", "\u001b[?2004h> "]
[376.320364, "o", "        (let ((name (car tail))\r\n\u001b[?2004l\r"]
[376.320376, "o", "\u001b[?2004h> "]
[376.320426, "o", "              (body (car (cdr tail))))\r\n\u001b[?2004l\r"]
[376.320438, "o", "\u001b[?2004h> "]
[376.320468, "o", "          (if (pair? name)\r\n\u001b[?2004l\r"]
[376.32048, "o", "\u001b[?2004h> "]
[376.320554, "o", "              (env-define (car name) (eval (cons 'lambda (cons (cdr name) body))))\r\n\u001b[?2004l\r"]
[376.320567, "o", "\u001b[?2004h> "]
[376.320609, "o", "              (env-define name (eval body)))))\r\n\u001b[?2004l\r"]
[376.32062, "o", "\u001b[?2004h> "]
[376.32065, "o", "       ((equal? head 'set!)\r\n\u001b[?2004l\r"]
[376.320665, "o", "\u001b[?2004h> "]
[376.320714, "o", "        (env-set! (car tail) (eval (car (cdr tail)))))\r\n\u001b[?2004l\r"]
[376.320726, "o", "\u001b[?2004h> "]
[376.320756, "o", "       ((equal? head 'lambda)\r\n\u001b[?2004l\r"]
[376.320767, "o", "\u001b[?2004h> "]
[376.320814, "o", "        (list 'procedure (car tail) (cdr tail)))\r\n\u001b[?2004l\r"]
[376.320826, "o", "\u001b[?2004h> "]
[376.320853, "o", "       ((equal? head 'cond)\r\n\u001b[?2004l\r"]
[376.320865, "o", "\u001b[?2004h> "]
[376.32089, "o", "        (eval-cond tail))\r\n\u001b[?2004l\r"]
[376.320902, "o", "\u001b[?2004h> "]
[376.320927, "o", "       ((equal? head 'let)\r\n\u001b[?2004l\r"]
[376.320939, "o", "\u001b[?2004h> "]
[376.320963, "o", "        (eval-let tail))\r\n\u001b[?2004l\r"]
[376.320976, "o", "\u001b[?2004h> "]
[376.321004, "o", "       ((equal? head 'progn)\r\n\u001b[?2004l\r"]
[376.321017, "o", "\u001b[?2004h> "]
[376.321044, "o", "        (eval-sequence tail))\r\n\u001b[?2004l\r"]
[376.321055, "o", "\u001b[?2004h> "]
[376.321069, "o", "       (else\r\n\u001b[?2004l\r"]
[376.321081, "o", "\u001b[?2004h> "]
[376.321115, "o", "        (apply (eval head) tail))))\r\n\u001b[?2004l\r"]
[376.321127, "o", "\u001b[?2004h> "]
[376.32114, "o", "     (else\r\n\u001b[?2004l\r"]
[376.321151, "o", "\u001b[?2004h> "]
[376.321183, "o", "      (apply (eval head) tail)))))\r\n\u001b[?2004l\r"]
[376.321195, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[376.321208, "o", "\u001b[?2004h> "]
[376.321234, "o", "(define (eval-cond clauses)\r\n\u001b[?2004l\r"]
[376.321247, "o", "\u001b[?2004h> "]
[376.321268, "o", "  (if (null? clauses)\r\n\u001b[?2004l\r"]
[376.32128, "o", "\u001b[?2004h> "]
[376.321292, "o", "      #f\r\n\u001b[?2004l\r\u001b[?2004h"]
[376.321303, "o", "> "]
[376.321333, "o", "      (let ((first (car clauses)))\r\n\u001b[?2004l\r"]
[376.321344, "o", "\u001b[?2004h> "]
[376.321377, "o", "        (let ((pred (car first))\r\n\u001b[?2004l\r"]
[376.321388, "o", "\u001b[?2004h> "]
[376.32142, "o", "              (body (cdr first)))\r\n\u001b[?2004l\r"]
[376.321432, "o", "\u001b[?2004h> "]
[376.321456, "o", "          (if (eval pred)\r\n\u001b[?2004l\r"]
[376.321468, "o", "\u001b[?2004h> "]
[376.321501, "o", "              (eval-sequence body)\r\n\u001b[?2004l\r"]
[376.321513, "o", "\u001b[?2004h> "]
[376.321554, "o", "              (eval-cond (cdr clauses)))))))\r\n\u001b[?2004l\r"]
[376.321565, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[376.321576, "o", "\u001b[?2004h> "]
[376.321609, "o", "(define (eval-let bindings body)\r\n\u001b[?2004l\r"]
[376.321621, "o", "\u001b[?2004h> "]
[376.321661, "o", "  (let ((names (map car bindings))\r\n\u001b[?2004l\r"]
[376.321675, "o", "\u001b[?2004h> "]
[376.321706, "o", "        (vals (map cadr bindings)))\r\n\u001b[?2004l\r"]
[376.321718, "o", "\u001b[?2004h> "]
[376.321759, "o", "    (eval (cons 'lambda (cons names body)))))\r\n\u001b[?2004l\r"]
[376.321771, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[376.321783, "o", "\u001b[?2004h> "]
[376.321812, "o", "(define (eval-sequence exprs)\r\n\u001b[?2004l\r"]
[376.321823, "o", "\u001b[?2004h> "]
[376.321844, "o", "  (if (null? exprs)\r\n\u001b[?2004l\r"]
[376.321856, "o", "\u001b[?2004h> "]
[376.321869, "o", "      #f\r\n\u001b[?2004l\r"]
[376.32188, "o", "\u001b[?2004h> "]
[376.321908, "o", "      (let ((first (car exprs))\r\n\u001b[?2004l\r"]
[376.321919, "o", "\u001b[?2004h> "]
[376.321949, "o", "            (rest (cdr exprs)))\r\n\u001b[?2004l\r"]
[376.321962, "o", "\u001b[?2004h> "]
[376.321985, "o", "        (if (null? rest)\r\n\u001b[?2004l\r"]
[376.321997, "o", "\u001b[?2004h> "]
[376.322021, "o", "            (eval first)\r\n\u001b[?2004l\r"]
[376.322033, "o", "\u001b[?2004h> "]
[376.322085, "o", "            (progn (eval first) (eval-sequence rest))))))\r\n\u001b[?2004l\r"]
[376.322097, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[376.322109, "o", "\u001b[?2004h> "]
[376.32214, "o", ";; Apply a procedure to arguments\r\n\u001b[?2004l\r"]
[376.322152, "o", "\u001b[?2004h> "]
[376.322178, "o", "(define (apply proc args)\r\n\u001b[?2004l\r"]
[376.322189, "o", "\u001b[?2004h> "]
[376.3222, "o", "  (cond\r\n\u001b[?2004l\r"]
[376.322212, "o", "\u001b[?2004h> "]
[376.32226, "o", "   ((and (pair? proc) (equal? (car proc) 'procedure))\r\n\u001b[?2004l\r"]
[376.322272, "o", "\u001b[?2004h> "]
[376.322301, "o", "    (let ((params (cadr proc))\r\n\u001b[?2004l\r"]
[376.322312, "o", "\u001b[?2004h> "]
[376.322343, "o", "          (body (caddr proc)))\r\n\u001b[?2004l\r"]
[376.322355, "o", "\u001b[?2004h> "]
[376.32238, "o", "      (let ((old-env env))\r\n\u001b[?2004l\r"]
[376.322392, "o", "\u001b[?2004h> "]
[376.32245, "o", "        (for-each (lambda (p a) (env-define p a)) params args)\r\n\u001b[?2004l\r"]
[376.322464, "o", "\u001b[?2004h> "]
[376.322508, "o", "        (let ((result (eval-sequence body)))\r\n\u001b[?2004l\r"]
[376.32252, "o", "\u001b[?2004h> "]
[376.322547, "o", "          (set! env old-env)\r\n\u001b[?2004l\r"]
[376.32256, "o", "\u001b[?2004h> "]
[376.32258, "o", "          result))))\r\n\u001b[?2004l\r"]
[376.322592, "o", "\u001b[?2004h> "]
[376.322639, "o", "   ((and (pair? proc) (equal? (car proc) 'builtin))\r\n\u001b[?2004l\r"]
[376.32265, "o", "\u001b[?2004h> "]
[376.322696, "o", "    (apply-builtin (cadr proc) args))\r\n\u001b[?2004l\r"]
[376.322708, "o", "\u001b[?2004h> "]
[376.322724, "o", "   (else\r\n\u001b[?2004l\r"]
[376.322736, "o", "\u001b[?2004h> "]
[376.322779, "o", "    (display \"Cannot apply: \")\r\n\u001b[?2004l\r"]
[376.322791, "o", "\u001b[?2004h> "]
[376.32282, "o", "    (display proc)\r\n\u001b[?2004l\r"]
[376.322831, "o", "\u001b[?2004h> "]
[376.322847, "o", "    (newline)\r\n\u001b[?2004l\r"]
[376.322859, "o", "\u001b[?2004h> "]
[376.32287, "o", "    #f)))\r\n\u001b[?2004l\r"]
[376.322883, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[376.322894, "o", "\u001b[?2004h> "]
[376.322917, "o", ";; Built-in procedures\r\n\u001b[?2004l\r"]
[376.322927, "o", "\u001b[?2004h> "]
[376.322961, "o", "(define (apply-builtin proc args)\r\n\u001b[?2004l\r"]
[376.322974, "o", "\u001b[?2004h> "]
[376.322987, "o", "  (cond\r\n\u001b[?2004l\r\u001b[?2004h"]
[376.322999, "o", "> "]
[376.323032, "o", "   ((equal? proc '+) (apply-op + args))\r\n\u001b[?2004l\r"]
[376.323044, "o", "\u001b[?2004h> "]
[376.323081, "o", "   ((equal? proc '-) (apply-op - args))\r\n\u001b[?2004l\r"]
[376.323092, "o", "\u001b[?2004h> "]
[376.323129, "o", "   ((equal? proc '*) (apply-op * args))\r\n\u001b[?2004l\r"]
[376.323141, "o", "\u001b[?2004h> "]
[376.323179, "o", "   ((equal? proc '/) (apply-op / args))\r\n\u001b[?2004l\r"]
[376.323191, "o", "\u001b[?2004h> "]
[376.32323, "o", "   ((equal? proc '=) (apply-comp = args))\r\n\u001b[?2004l\r"]
[376.323241, "o", "\u001b[?2004h> "]
[376.32328, "o", "   ((equal? proc '<) (apply-comp < args))\r\n\u001b[?2004l\r"]
[376.323292, "o", "\u001b[?2004h> "]
[376.323331, "o", "   ((equal? proc '>) (apply-comp > args))\r\n\u001b[?2004l\r"]
[376.323342, "o", "\u001b[?2004h> "]
[376.323384, "o", "   ((equal? proc '<=) (apply-comp <= args))\r\n\u001b[?2004l\r"]
[376.323395, "o", "\u001b[?2004h> "]
[376.323436, "o", "   ((equal? proc '>=) (apply-comp >= args))\r\n\u001b[?2004l\r"]
[376.323448, "o", "\u001b[?2004h> "]
[376.323486, "o", "   ((equal? proc 'car) (car (car args)))\r\n\u001b[?2004l\r"]
[376.323498, "o", "\u001b[?2004h> "]
[376.323536, "o", "   ((equal? proc 'cdr) (cdr (car args)))\r\n\u001b[?2004l\r"]
[376.323548, "o", "\u001b[?2004h> "]
[376.323597, "o", "   ((equal? proc 'cons) (cons (car args) (cadr args)))\r\n\u001b[?2004l\r"]
[376.32361, "o", "\u001b[?2004h> "]
[376.323663, "o", "   ((equal? proc 'null?) (if (null? (car args)) #t #f))\r\n\u001b[?2004l\r"]
[376.32367, "o", "\u001b[?2004h"]
[376.323689, "o", "> "]
[376.323745, "o", "   ((equal? proc 'equal?) (if (equal? (car args) (cadr args)) #t #f))\r\n\u001b[?2004l\r"]
[376.323758, "o", "\u001b[?2004h> "]
[376.323815, "o", "   ((equal? proc 'eq?) (if (eq? (car args) (cadr args)) #t #f))\r\n\u001b[?2004l\r"]
[376.323827, "o", "\u001b[?2004h> "]
[376.323876, "o", "   ((equal? proc 'pair?) (if (pair? (car args)) #t #f))\r\n\u001b[?2004l\r"]
[376.323888, "o", "\u001b[?2004h> "]
[376.323935, "o", "   ((equal? proc 'display) (display (car args)) #f)\r\n\u001b[?2004l\r"]
[376.323948, "o", "\u001b[?2004h> "]
[376.323985, "o", "   ((equal? proc 'newline) (newline) #f)\r\n\u001b[?2004l\r"]
[376.323997, "o", "\u001b[?2004h> "]
[376.324027, "o", "   ((equal? proc 'read) (read))\r\n\u001b[?2004l\r"]
[376.324039, "o", "\u001b[?2004h> "]
[376.324087, "o", "   ((equal? proc 'putchr) (fputchr 0 (car args)) #f)\r\n\u001b[?2004l\r"]
[376.324104, "o", "\u001b[?2004h> "]
[376.324158, "o", "   ((equal? proc 'fopen) (fopen (car args) (cadr args)))\r\n\u001b[?2004l\r"]
[376.324171, "o", "\u001b[?2004h> "]
[376.324216, "o", "   ((equal? proc 'fclose) (fclose (car args)) #f)\r\n\u001b[?2004l\r"]
[376.324226, "o", "\u001b[?2004h> "]
[376.324269, "o", "   ((equal? proc 'fread) (fread (car args)))\r\n\u001b[?2004l\r"]
[376.324281, "o", "\u001b[?2004h> "]
[376.32434, "o", "   ((equal? proc 'fdisplay) (fdisplay (car args) (cadr args)) #f)\r\n\u001b[?2004l\r"]
[376.324351, "o", "\u001b[?2004h> "]
[376.324409, "o", "   ((equal? proc 'fputchr) (fputchr (car args) (cadr args)) #f)\r\n\u001b[?2004l\r"]
[376.324421, "o", "\u001b[?2004h> "]
[376.324434, "o", "   (else\r\n\u001b[?2004l\r"]
[376.324446, "o", "\u001b[?2004h> "]
[376.324473, "o", "    (display \"Unknown builtin: \")\r\n\u001b[?2004l\r"]
[376.324484, "o", "\u001b[?2004h> "]
[376.324505, "o", "    (display proc)\r\n\u001b[?2004l\r"]
[376.324517, "o", "\u001b[?2004h> "]
[376.32453, "o", "    (newline)\r\n\u001b[?2004l\r"]
[376.324542, "o", "\u001b[?2004h> "]
[376.324553, "o", "    #f)))\r\n\u001b[?2004l\r"]
[376.324565, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[376.324576, "o", "\u001b[?2004h> "]
[376.324603, "o", "(define (apply-op op args)\r\n\u001b[?2004l\r"]
[376.324615, "o", "\u001b[?2004h> "]
[376.324634, "o", "  (if (null? args)\r\n\u001b[?2004l\r"]
[376.324646, "o", "\u001b[?2004h> "]
[376.324662, "o", "      0\r\n\u001b[?2004l\r"]
[376.324675, "o", "\u001b[?2004h> "]
[376.324724, "o", "      (let loop ((acc (car args)) (rest (cdr args)))\r\n\u001b[?2004l\r"]
[376.324736, "o", "\u001b[?2004h> "]
[376.32476, "o", "        (if (null? rest)\r\n\u001b[?2004l\r"]
[376.324772, "o", "\u001b[?2004h> "]
[376.324788, "o", "            acc\r\n\u001b[?2004l\r"]
[376.3248, "o", "\u001b[?2004h> "]
[376.324849, "o", "            (loop (op acc (car rest)) (cdr rest))))))\r\n\u001b[?2004l\r"]
[376.324861, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[376.324871, "o", "\u001b[?2004h> "]
[376.324901, "o", "(define (apply-comp op args)\r\n\u001b[?2004l\r"]
[376.324912, "o", "\u001b[?2004h> "]
[376.324933, "o", "  (if (null? args)\r\n\u001b[?2004l\r"]
[376.324945, "o", "\u001b[?2004h> "]
[376.324957, "o", "      #t\r\n\u001b[?2004l\r"]
[376.324969, "o", "\u001b[?2004h> "]
[376.325015, "o", "      (let loop ((prev (car args)) (rest (cdr args)))\r\n\u001b[?2004l\r"]
[376.325027, "o", "\u001b[?2004h> "]
[376.325051, "o", "        (if (null? rest)\r\n\u001b[?2004l\r"]
[376.325063, "o", "\u001b[?2004h> "]
[376.325078, "o", "            #t\r\n\u001b[?2004l\r"]
[376.325089, "o", "\u001b[?2004h> "]
[376.325123, "o", "            (if (op prev (car rest))\r\n\u001b[?2004l\r"]
[376.325136, "o", "\u001b[?2004h> "]
[376.325177, "o", "                (loop (car rest) (cdr rest))\r\n\u001b[?2004l\r"]
[376.325188, "o", "\u001b[?2004h> "]
[376.325213, "o", "                #f)))))\r\n\u001b[?2004l\r"]
[376.325225, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[376.325236, "o", "\u001b[?2004h> "]
[376.325256, "o", "(define (map f lst)\r\n\u001b[?2004l\r"]
[376.325269, "o", "\u001b[?2004h> "]
[376.325286, "o", "  (if (null? lst)\r\n\u001b[?2004l\r"]
[376.325298, "o", "\u001b[?2004h> "]
[376.325309, "o", "      '()\r\n\u001b[?2004l\r"]
[376.32532, "o", "\u001b[?2004h> "]
[376.325363, "o", "      (cons (f (car lst)) (map f (cdr lst)))))\r\n\u001b[?2004l\r"]
[376.325376, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[376.325388, "o", "\u001b[?2004h> "]
[376.325412, "o", "(define (for-each f lst)\r\n\u001b[?2004l\r"]
[376.325423, "o", "\u001b[?2004h> "]
[376.325442, "o", "  (if (null? lst)\r\n\u001b[?2004l\r"]
[376.325453, "o", "\u001b[?2004h> "]
[376.325464, "o", "      #f\r\n\u001b[?2004l\r"]
[376.325474, "o", "\u001b[?2004h> "]
[376.325523, "o", "      (progn (f (car lst)) (for-each f (cdr lst)))))\r\n\u001b[?2004l\r"]
[376.325536, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[376.325546, "o", "\u001b[?2004h> "]
[376.325584, "o", ";; Main: read file path and interpret\r\n\u001b[?2004l\r"]
[376.325595, "o", "\u001b[?2004h> "]
[376.325625, "o", "(let ((filepath (read-line)))\r\n\u001b[?2004l\r"]
[376.325636, "o", "\u001b[?2004h> "]
[376.325652, "o", "  (if filepath\r\n\u001b[?2004l\r"]
[376.325679, "o", "\u001b[?2004h> "]
[376.325705, "o", "      (interpret-file filepath)))\r\n\u001b[?2004l\r"]
[376.325717, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[376.325729, "o", "\u001b[?2004h> "]
[376.325774, "o", ";; Continue reading and interpreting from stdin\r\n\u001b[?2004l\r"]
[376.325786, "o", "\u001b[?2004h> "]
[376.325802, "o", "(let loop ()\r\n\u001b[?2004l\r"]
[376.325814, "o", "\u001b[?2004h> "]
[376.325837, "o", "  (let ((expr (read)))\r\n\u001b[?2004l\r"]
[376.325848, "o", "\u001b[?2004h> "]
[376.32588, "o", "    (if (not (equal? expr #f))\r\n\u001b[?2004l\r"]
[376.325892, "o", "\u001b[?2004h> "]
[376.325908, "o", "        (progn\r\n\u001b[?2004l\r"]
[376.32592, "o", "\u001b[?2004h> "]
[376.325941, "o", "          (eval expr)\r\n\u001b[?2004l\r"]
[376.325954, "o", "\u001b[?2004h> "]
[376.325975, "o", "          (loop)))))\r\n\u001b[?2004l\r"]
[376.325988, "o", "\u001b[?2004h> EOF\r\n"]
