[302.61987, "o", "\u001b[?2004h> "]
[302.619883, "o", "            #t\r\n\u001b[?2004l\r"]
[302.619896, "o", "\u001b[?2004h> "]
[302.619925, "o", "            (if (op prev (car rest))\r\n\u001b[?2004l\r"]
[302.619936, "o", "\u001b[?2004h> "]
