[103.2311, "o", "\u001b[?2004h"]
[103.231116, "o", "> "]
[103.231134, "o", "       ((equal? car 'let)\r\n\u001b[?2004l\r"]
[103.23115, "o", "\u001b[?2004h"]
[103.231164, "o", "> "]
