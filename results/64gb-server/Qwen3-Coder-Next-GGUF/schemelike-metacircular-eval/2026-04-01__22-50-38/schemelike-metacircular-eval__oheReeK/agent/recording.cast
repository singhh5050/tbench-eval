[302.616609, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[302.616631, "o", "\u001b[?2004h> "]
[302.61666, "o", "(define (eval-let bindings body)\r\n\u001b[?2004l\r"]
[302.616669, "o", "\u001b[?2004h> "]
[302.616735, "o", "  (let ((names (map car bindings))\r\n\u001b[?2004l\r\u001b[?2004h>         (vals (map cadr bindings)))\r\n\u001b[?2004l\r"]
[302.616759, "o", "\u001b[?2004h> "]
