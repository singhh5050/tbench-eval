[302.619987, "o", "\u001b[?2004h"]
[302.62, "o", "> "]
[302.620011, "o", "                #f)))))\r\n\u001b[?2004l\r"]
[302.620026, "o", "\u001b[?2004h"]
[302.620037, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[302.62005, "o", "(define (map f lst)\r\n\u001b[?2004l\r"]
[302.620064, "o", "\u001b[?2004h> "]
