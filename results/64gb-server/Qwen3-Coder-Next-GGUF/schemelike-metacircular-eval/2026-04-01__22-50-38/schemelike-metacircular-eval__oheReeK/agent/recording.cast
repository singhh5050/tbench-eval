[302.619672, "o", "\u001b[?2004h"]
[302.619707, "o", "> "]
[302.619756, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> (define (apply-comp op args)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[302.61977, "o", "  (if (null? args)\r\n\u001b[?2004l\r\u001b[?2004h>       #t\r\n\u001b[?2004l\r"]
[302.619785, "o", "\u001b[?2004h> "]
