[164.315001, "o", "          (display filename)\r\n\u001b[?2004l\r"]
[164.315014, "o", "\u001b[?2004h> "]
[164.315045, "o", "          (newline))\r\n\u001b[?2004l\r"]
[164.315057, "o", "\u001b[?2004h> "]
[164.315088, "o", "        (let loop ()\r\n\u001b[?2004l\r"]
[164.315099, "o", "\u001b[?2004h> "]
[164.315143, "o", "          (let ((expr (fread f)))\r\n\u001b[?2004l\r"]
[164.315158, "o", "\u001b[?2004h> "]
[164.315206, "o", "            (if (not (equal? expr #f))\r\n\u001b[?2004l\r"]
[164.315218, "o", "\u001b[?2004h> "]
[164.31525, "o", "                (progn\r\n\u001b[?2004l\r"]
[164.315263, "o", "\u001b[?2004h> "]
[164.315305, "o", "                  (eval expr)\r\n\u001b[?2004l\r"]
[164.315318, "o", "\u001b[?2004h> "]
[164.315354, "o", "                  (loop))\r\n\u001b[?2004l\r"]
[164.315365, "o", "\u001b[?2004h> "]
[164.315411, "o", "                (fclose f)))))))\r\n\u001b[?2004l\r"]
[164.315423, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[164.315434, "o", "\u001b[?2004h> "]
[164.315471, "o", ";; The main eval function\r\n\u001b[?2004l\r"]
[164.315484, "o", "\u001b[?2004h> "]
[164.315512, "o", "(define (eval expr)\r\n\u001b[?2004l\r"]
[164.315524, "o", "\u001b[?2004h> "]
[164.315536, "o", "  (cond\r\n\u001b[?2004l\r"]
[164.31555, "o", "\u001b[?2004h> "]
[164.315584, "o", "   ((number? expr) expr)\r\n\u001b[?2004l\r"]
[164.315596, "o", "\u001b[?2004h> "]
[164.315632, "o", "   ((boolean? expr) expr)\r\n\u001b[?2004l\r"]
[164.315645, "o", "\u001b[?2004h> "]
[164.315686, "o", "   ((string? expr) expr)\r\n\u001b[?2004l\r"]
[164.315699, "o", "\u001b[?2004h> "]
[164.315744, "o", "   ((symbol? expr) (env-get expr))\r\n\u001b[?2004l\r"]
[164.315756, "o", "\u001b[?2004h> "]
[164.315781, "o", "   ((pair? expr)\r\n\u001b[?2004l\r"]
[164.315792, "o", "\u001b[?2004h> "]
[164.315825, "o", "    (eval-pair expr))\r\n\u001b[?2004l\r"]
[164.315838, "o", "\u001b[?2004h> "]
[164.315862, "o", "   (else expr)))\r\n\u001b[?2004l\r"]
[164.315874, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[164.315886, "o", "\u001b[?2004h> "]
[164.315922, "o", "(define (eval-pair expr)\r\n\u001b[?2004l\r"]
[164.315934, "o", "\u001b[?2004h> "]
[164.315967, "o", "  (let ((car (car expr))\r\n\u001b[?2004l\r"]
[164.315979, "o", "\u001b[?2004h> "]
[164.316017, "o", "        (cdr (cdr expr)))\r\n\u001b[?2004l\r"]
[164.316029, "o", "\u001b[?2004h> "]
[164.316044, "o", "    (cond\r\n\u001b[?2004l\r"]
[164.316056, "o", "\u001b[?2004h> "]
[164.316086, "o", "     ((symbol? car)\r\n\u001b[?2004l\r"]
[164.316098, "o", "\u001b[?2004h> "]
[164.316116, "o", "      (cond\r\n\u001b[?2004l\r"]
[164.316129, "o", "\u001b[?2004h> "]
[164.316168, "o", "       ((equal? car 'quote)\r\n\u001b[?2004l\r"]
[164.316181, "o", "\u001b[?2004h> "]
[164.316208, "o", "        (car cdr))\r\n\u001b[?2004l\r"]
[164.316221, "o", "\u001b[?2004h> "]
[164.316255, "o", "       ((equal? car 'if)\r\n\u001b[?2004l\r"]
[164.316267, "o", "\u001b[?2004h> "]
[164.316308, "o", "        (if (eval (car cdr))\r\n\u001b[?2004l\r"]
[164.31632, "o", "\u001b[?2004h> "]
[164.316368, "o", "            (eval (car (cdr cdr)))\r\n\u001b[?2004l\r"]
[164.316381, "o", "\u001b[?2004h> "]
[164.316434, "o", "            (if (null? (cdr (cdr cdr)))\r\n\u001b[?2004l\r"]
[164.316446, "o", "\u001b[?2004h> "]
[164.316475, "o", "                #f\r\n\u001b[?2004l\r"]
[164.316486, "o", "\u001b[?2004h> "]
[164.316531, "o", "                (eval (car (cdr (cdr cdr)))))))\r\n\u001b[?2004l\r"]
[164.316544, "o", "\u001b[?2004h> "]
[164.316572, "o", "       ((equal? car 'define)\r\n\u001b[?2004l\r"]
[164.316585, "o", "\u001b[?2004h> "]
[164.316612, "o", "        (let ((name (car cdr))\r\n\u001b[?2004l\r"]
[164.316624, "o", "\u001b[?2004h> "]
[164.316661, "o", "              (body (car (cdr cdr))))\r\n\u001b[?2004l\r"]
[164.316674, "o", "\u001b[?2004h"]
[164.316687, "o", "> "]
[164.316701, "o", "          (if (pair? name)\r\n\u001b[?2004l\r"]
[164.316714, "o", "\u001b[?2004h> "]
[164.316786, "o", "              (env-define (car name) (eval (cons 'lambda (cons (cdr name) body))))\r\n\u001b[?2004l\r"]
[164.3168, "o", "\u001b[?2004h> "]
[164.316842, "o", "              (env-define name (eval body)))))\r\n\u001b[?2004l\r"]
[164.316859, "o", "\u001b[?2004h> "]
[164.316879, "o", "       ((equal? car 'set!)\r\n\u001b[?2004l\r"]
[164.316892, "o", "\u001b[?2004h> "]
[164.316939, "o", "        (env-set! (car cdr) (eval (car (cdr cdr)))))\r\n\u001b[?2004l\r"]
[164.316952, "o", "\u001b[?2004h> "]
[164.316979, "o", "       ((equal? car 'lambda)\r\n\u001b[?2004l\r"]
[164.316991, "o", "\u001b[?2004h> "]
[164.317034, "o", "        (list 'procedure (car cdr) (cdr cdr)))\r\n\u001b[?2004l\r"]
[164.317046, "o", "\u001b[?2004h> "]
[164.317071, "o", "       ((equal? car 'cond)\r\n\u001b[?2004l\r"]
[164.317084, "o", "\u001b[?2004h> "]
[164.317107, "o", "        (eval-cond cdr))\r\n\u001b[?2004l\r"]
[164.317119, "o", "\u001b[?2004h> "]
[164.317143, "o", "       ((equal? car 'let)\r\n\u001b[?2004l\r"]
[164.317155, "o", "\u001b[?2004h> "]
[164.317177, "o", "        (eval-let cdr))\r\n\u001b[?2004l\r"]
[164.317189, "o", "\u001b[?2004h> "]
[164.317216, "o", "       ((equal? car 'progn)\r\n\u001b[?2004l\r"]
[164.317228, "o", "\u001b[?2004h> "]
[164.317256, "o", "        (eval-sequence cdr))\r\n\u001b[?2004l\r"]
[164.31727, "o", "\u001b[?2004h> "]
[164.317282, "o", "       (else\r\n\u001b[?2004l\r"]
[164.317293, "o", "\u001b[?2004h> "]
[164.317326, "o", "        (apply (eval car) cdr))))\r\n\u001b[?2004l\r"]
[164.317339, "o", "\u001b[?2004h> "]
[164.317351, "o", "     (else\r\n\u001b[?2004l\r"]
[164.317363, "o", "\u001b[?2004h> "]
[164.317393, "o", "      (apply (eval car) cdr)))))\r\n\u001b[?2004l\r"]
[164.317405, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[164.317417, "o", "\u001b[?2004h> "]
[164.317444, "o", "(define (eval-cond clauses)\r\n\u001b[?2004l\r"]
[164.317457, "o", "\u001b[?2004h> "]
[164.317478, "o", "  (if (null? clauses)\r\n\u001b[?2004l\r"]
[164.317491, "o", "\u001b[?2004h> "]
[164.317501, "o", "      #f\r\n\u001b[?2004l\r"]
[164.317512, "o", "\u001b[?2004h> "]
[164.317544, "o", "      (let ((first (car clauses)))\r\n\u001b[?2004l\r"]
[164.317555, "o", "\u001b[?2004h> "]
[164.317586, "o", "        (let ((pred (car first))\r\n\u001b[?2004l\r"]
[164.3176, "o", "\u001b[?2004h> "]
[164.317631, "o", "              (body (cdr first)))\r\n\u001b[?2004l\r"]
[164.317643, "o", "\u001b[?2004h> "]
[164.317681, "o", "          (if (eval pred)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[164.317715, "o", "              (eval-sequence body)\r\n\u001b[?2004l\r"]
[164.317727, "o", "\u001b[?2004h> "]
[164.317771, "o", "              (eval-cond (cdr clauses)))))))\r\n\u001b[?2004l\r"]
[164.317783, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[164.317795, "o", "\u001b[?2004h> "]
[164.317823, "o", "(define (eval-let bindings body)\r\n\u001b[?2004l\r"]
[164.317835, "o", "\u001b[?2004h> "]
[164.317868, "o", "  (let ((names (map car bindings))\r\n\u001b[?2004l\r"]
[164.31788, "o", "\u001b[?2004h> "]
[164.317916, "o", "        (vals (map cadr bindings)))\r\n\u001b[?2004l\r"]
[164.317928, "o", "\u001b[?2004h> "]
[164.31797, "o", "    (eval (cons 'lambda (cons names body)))))\r\n\u001b[?2004l\r"]
[164.317982, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[164.317994, "o", "\u001b[?2004h> "]
[164.318022, "o", "(define (eval-sequence exprs)\r\n\u001b[?2004l\r"]
[164.318035, "o", "\u001b[?2004h> "]
[164.318054, "o", "  (if (null? exprs)\r\n\u001b[?2004l\r"]
[164.318066, "o", "\u001b[?2004h> "]
[164.318077, "o", "      #f\r\n\u001b[?2004l\r"]
[164.318087, "o", "\u001b[?2004h> "]
[164.318115, "o", "      (let ((first (car exprs))\r\n\u001b[?2004l\r"]
[164.318128, "o", "\u001b[?2004h> "]
[164.318158, "o", "            (rest (cdr exprs)))\r\n\u001b[?2004l\r"]
[164.318171, "o", "\u001b[?2004h> "]
[164.318194, "o", "        (if (null? rest)\r\n\u001b[?2004l\r"]
[164.318208, "o", "\u001b[?2004h> "]
[164.318228, "o", "            (eval first)\r\n\u001b[?2004l\r"]
[164.318241, "o", "\u001b[?2004h> "]
[164.318295, "o", "            (progn (eval first) (eval-sequence rest))))))\r\n\u001b[?2004l\r"]
[164.318307, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[164.31832, "o", "\u001b[?2004h> "]
[164.31835, "o", ";; Apply a procedure to arguments\r\n\u001b[?2004l\r"]
[164.318363, "o", "\u001b[?2004h> "]
[164.318387, "o", "(define (apply proc args)\r\n\u001b[?2004l\r"]
[164.318399, "o", "\u001b[?2004h> "]
[164.318449, "o", "  (if (and (pair? proc) (equal? (car proc) 'procedure))\r\n\u001b[?2004l\r"]
[164.318461, "o", "\u001b[?2004h> "]
[164.318492, "o", "      (let ((params (cadr proc))\r\n\u001b[?2004l\r"]
[164.318505, "o", "\u001b[?2004h> "]
[164.318535, "o", "            (body (caddr proc)))\r\n\u001b[?2004l\r"]
[164.318547, "o", "\u001b[?2004h> "]
[164.318575, "o", "        (let ((old-env env))\r\n\u001b[?2004l\r"]
[164.318587, "o", "\u001b[?2004h> "]
[164.318645, "o", "          (for-each (lambda (p a) (env-define p a)) params args)\r\n\u001b[?2004l\r"]
[164.318661, "o", "\u001b[?2004h> "]
[164.318704, "o", "          (let ((result (eval-sequence body)))\r\n\u001b[?2004l\r"]
[164.318717, "o", "\u001b[?2004h> "]
[164.318745, "o", "            (set! env old-env)\r\n\u001b[?2004l\r"]
[164.318757, "o", "\u001b[?2004h> "]
[164.318778, "o", "            result)))\r\n\u001b[?2004l\r"]
[164.31879, "o", "\u001b[?2004h> "]
[164.318822, "o", "      (apply-builtin proc args)))\r\n\u001b[?2004l\r"]
[164.318834, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[164.318846, "o", "\u001b[?2004h> "]
[164.318869, "o", ";; Built-in procedures\r\n\u001b[?2004l\r"]
[164.318879, "o", "\u001b[?2004h> "]
[164.318912, "o", "(define (apply-builtin proc args)\r\n\u001b[?2004l\r"]
[164.318925, "o", "\u001b[?2004h> "]
[164.318936, "o", "  (cond\r\n\u001b[?2004l\r\u001b[?2004h"]
[164.318949, "o", "> "]
[164.318981, "o", "   ((equal? proc '+) (apply-op + args))\r\n\u001b[?2004l\r"]
[164.318994, "o", "\u001b[?2004h> "]
[164.31903, "o", "   ((equal? proc '-) (apply-op - args))\r\n\u001b[?2004l\r"]
[164.319043, "o", "\u001b[?2004h> "]
[164.319078, "o", "   ((equal? proc '*) (apply-op * args))\r\n\u001b[?2004l\r"]
[164.319091, "o", "\u001b[?2004h> "]
[164.319126, "o", "   ((equal? proc '/) (apply-op / args))\r\n\u001b[?2004l\r"]
[164.319139, "o", "\u001b[?2004h> "]
[164.319177, "o", "   ((equal? proc '=) (apply-comp = args))\r\n\u001b[?2004l\r"]
[164.319189, "o", "\u001b[?2004h> "]
[164.319227, "o", "   ((equal? proc '<) (apply-comp < args))\r\n\u001b[?2004l\r"]
[164.319238, "o", "\u001b[?2004h> "]
[164.319278, "o", "   ((equal? proc '>) (apply-comp > args))\r\n\u001b[?2004l\r"]
[164.31929, "o", "\u001b[?2004h> "]
[164.31933, "o", "   ((equal? proc '<=) (apply-comp <= args))\r\n\u001b[?2004l\r"]
[164.319342, "o", "\u001b[?2004h> "]
[164.319382, "o", "   ((equal? proc '>=) (apply-comp >= args))\r\n\u001b[?2004l\r"]
[164.319394, "o", "\u001b[?2004h> "]
[164.319431, "o", "   ((equal? proc 'car) (car (car args)))\r\n\u001b[?2004l\r"]
[164.319443, "o", "\u001b[?2004h> "]
[164.31948, "o", "   ((equal? proc 'cdr) (cdr (car args)))\r\n\u001b[?2004l\r"]
[164.319492, "o", "\u001b[?2004h> "]
[164.319542, "o", "   ((equal? proc 'cons) (cons (car args) (cadr args)))\r\n\u001b[?2004l\r"]
[164.319554, "o", "\u001b[?2004h> "]
[164.319606, "o", "   ((equal? proc 'null?) (if (null? (car args)) #t #f))\r\n\u001b[?2004l\r"]
[164.319618, "o", "\u001b[?2004h> "]
[164.319716, "o", "   ((equal? proc 'equal?) (if (equal? (car args) (cadr args)) #t #f))\r\n"]
[164.319728, "o", "\u001b[?2004l\r"]
[164.319744, "o", "\u001b[?2004h> "]
[164.319806, "o", "   ((equal? proc 'eq?) (if (eq? (car args) (cadr args)) #t #f))\r\n\u001b[?2004l\r"]
[164.319819, "o", "\u001b[?2004h> "]
[164.319876, "o", "   ((equal? proc 'pair?) (if (pair? (car args)) #t #f))\r\n\u001b[?2004l\r"]
[164.319893, "o", "\u001b[?2004h> "]
[164.319946, "o", "   ((equal? proc 'display) (display (car args)) #f)\r\n\u001b[?2004l\r"]
[164.319957, "o", "\u001b[?2004h> "]
[164.319999, "o", "   ((equal? proc 'newline) (newline) #f)\r\n\u001b[?2004l\r"]
[164.320011, "o", "\u001b[?2004h> "]
[164.320046, "o", "   ((equal? proc 'read) (read))\r\n\u001b[?2004l\r"]
[164.320058, "o", "\u001b[?2004h> "]
[164.320105, "o", "   ((equal? proc 'putchr) (fputchr 0 (car args)) #f)\r\n\u001b[?2004l\r"]
[164.320116, "o", "\u001b[?2004h> "]
[164.320171, "o", "   ((equal? proc 'fopen) (fopen (car args) (cadr args)))\r\n\u001b[?2004l\r"]
[164.320183, "o", "\u001b[?2004h> "]
[164.32023, "o", "   ((equal? proc 'fclose) (fclose (car args)) #f)\r\n\u001b[?2004l\r"]
[164.320242, "o", "\u001b[?2004h> "]
[164.320283, "o", "   ((equal? proc 'fread) (fread (car args)))\r\n\u001b[?2004l\r"]
[164.320296, "o", "\u001b[?2004h> "]
[164.320356, "o", "   ((equal? proc 'fdisplay) (fdisplay (car args) (cadr args)) #f)\r\n\u001b[?2004l\r"]
[164.320369, "o", "\u001b[?2004h> "]
[164.320427, "o", "   ((equal? proc 'fputchr) (fputchr (car args) (cadr args)) #f)\r\n\u001b[?2004l\r"]
[164.32044, "o", "\u001b[?2004h> "]
[164.32045, "o", "   (else\r\n\u001b[?2004l\r"]
[164.320463, "o", "\u001b[?2004h> "]
[164.320501, "o", "    (display \"Unknown procedure: \")\r\n\u001b[?2004l\r"]
[164.320513, "o", "\u001b[?2004h> "]
[164.320535, "o", "    (display proc)\r\n\u001b[?2004l\r"]
[164.320548, "o", "\u001b[?2004h> "]
[164.320566, "o", "    (newline)\r\n\u001b[?2004l\r"]
[164.320577, "o", "\u001b[?2004h> "]
[164.320592, "o", "    #f)))\r\n\u001b[?2004l\r"]
[164.320604, "o", "\u001b[?2004h> "]
[164.320616, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[164.320628, "o", "> "]
[164.32065, "o", "(define (apply-op op args)\r\n\u001b[?2004l\r"]
[164.320666, "o", "\u001b[?2004h> "]
[164.320692, "o", "  (if (null? args)\r\n\u001b[?2004l\r"]
[164.320702, "o", "\u001b[?2004h> "]
[164.320716, "o", "      0\r\n\u001b[?2004l\r"]
[164.320728, "o", "\u001b[?2004h> "]
[164.320781, "o", "      (let loop ((acc (car args)) (rest (cdr args)))\r\n\u001b[?2004l\r"]
[164.320791, "o", "\u001b[?2004h> "]
[164.320821, "o", "        (if (null? rest)\r\n\u001b[?2004l\r"]
[164.320833, "o", "\u001b[?2004h> "]
[164.320854, "o", "            acc\r\n\u001b[?2004l\r"]
[164.320866, "o", "\u001b[?2004h> "]
[164.320917, "o", "            (loop (op acc (car rest)) (cdr rest))))))\r\n\u001b[?2004l\r"]
[164.320929, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[164.320941, "o", "\u001b[?2004h> "]
[164.320973, "o", "(define (apply-comp op args)\r\n\u001b[?2004l\r"]
[164.320983, "o", "\u001b[?2004h> "]
[164.321007, "o", "  (if (null? args)\r\n\u001b[?2004l\r"]
[164.321018, "o", "\u001b[?2004h> "]
[164.321031, "o", "      #t\r\n\u001b[?2004l\r"]
[164.321043, "o", "\u001b[?2004h> "]
[164.321095, "o", "      (let loop ((prev (car args)) (rest (cdr args)))\r\n\u001b[?2004l\r"]
[164.321108, "o", "\u001b[?2004h> "]
[164.321136, "o", "        (if (null? rest)\r\n\u001b[?2004l\r"]
[164.321148, "o", "\u001b[?2004h> "]
