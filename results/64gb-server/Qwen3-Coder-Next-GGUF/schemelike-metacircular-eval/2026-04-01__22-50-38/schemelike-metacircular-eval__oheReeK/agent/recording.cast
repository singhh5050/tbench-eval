[302.616963, "o", ">             (rest (cdr exprs)))\r\n\u001b[?2004l\r"]
[302.616984, "o", "\u001b[?2004h> "]
[302.617006, "o", "        (if (null? rest)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[302.617027, "o", "            (eval first)\r\n\u001b[?2004l\r"]
[302.617049, "o", "\u001b[?2004h> "]
[302.617088, "o", "            (progn (eval first) (eval-sequence rest))))))\r\n\u001b[?2004l\r"]
[302.61711, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[302.617131, "o", "\u001b[?2004h> "]
[302.617153, "o", ";; Apply a procedure to arguments\r\n\u001b[?2004l\r"]
[302.617174, "o", "\u001b[?2004h> (define (apply proc args)\r\n"]
[302.617195, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[302.617218, "o", "  (cond\r\n\u001b[?2004l\r\u001b[?2004h> "]
[302.617255, "o", "   ((and (pair? proc) (equal? (car proc) 'procedure))\r\n\u001b[?2004l\r"]
[302.617276, "o", "\u001b[?2004h> "]
[302.617297, "o", "    (let ((params (cadr proc))\r\n\u001b[?2004l\r\u001b[?2004h"]
[302.617317, "o", "> "]
[302.61734, "o", "          (body (caddr proc)))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[302.617368, "o", "      (let ((old-env env))\r\n\u001b[?2004l\r"]
[302.61739, "o", "\u001b[?2004h> "]
[302.617433, "o", "        (for-each (lambda (p a) (env-define p a)) params args)\r\n\u001b[?2004l\r"]
[302.617454, "o", "\u001b[?2004h> "]
[302.617484, "o", "        (let ((result (eval-sequence body)))\r\n\u001b[?2004l\r"]
[302.617506, "o", "\u001b[?2004h> "]
[302.617527, "o", "          (set! env old-env)\r\n\u001b[?2004l\r\u001b[?2004h"]
[302.617537, "o", "> "]
[302.617564, "o", "          result))))\r\n\u001b[?2004l\r"]
[302.617587, "o", "\u001b[?2004h> "]
[302.617609, "o", "   ((and (pair? proc) (equal? (car proc) 'builtin))\r\n\u001b[?2004l\r"]
