[103.232255, "o", "(define (eval-sequence exprs)\r\n\u001b[?2004l\r"]
[103.23227, "o", "\u001b[?2004h> "]
[103.232295, "o", "  (if (null? exprs)\r\n\u001b[?2004l\r"]
[103.232309, "o", "\u001b[?2004h> "]
