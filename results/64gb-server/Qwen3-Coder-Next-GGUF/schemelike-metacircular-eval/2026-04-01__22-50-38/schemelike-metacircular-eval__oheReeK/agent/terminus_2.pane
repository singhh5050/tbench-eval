  (display "> ")
  (let ((expr (read)))
    (if (eq? expr 'quit)
        (display "Goodbye!")
        (progn
          (display "You entered: ")
          (display expr)
          (newline)
          ;; In a real REPL, we'd evaluate expr here
          (mini-repl)))))

