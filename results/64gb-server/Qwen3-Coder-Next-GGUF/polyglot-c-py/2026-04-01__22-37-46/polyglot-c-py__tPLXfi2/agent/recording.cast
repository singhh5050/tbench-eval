[375.388658, "i", "cat > /app/polyglot/main.py.c << 'POLYGLOT'\n#if 0\n#endif\n#include <stdio.h>\n#include <stdlib.h>\nint main(int argc, char**argv) {\n    int n = atoi(argv[1]);\n    if (n <= 0) { printf(\"0\\n\"); return 0; }\n    int a = 0, b = 1;\n    for (int i = 1; i < n; i++) { int t = a + b; a = b; b = t; }\n    printf(\"%d\\n\", b);\n    return 0;\n}\nPOLYGLOT\n"]
