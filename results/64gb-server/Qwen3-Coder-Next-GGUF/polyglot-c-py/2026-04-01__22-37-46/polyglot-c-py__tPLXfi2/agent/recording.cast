[104.635864, "i", "cat > /app/polyglot/main.py.c << 'POLYGLOT'\n#if 0\n# Python sees this as a comment since it starts with #\nimport sys\nn = int(sys.argv[1])\nif n <= 0: print(0)\nelse:\n    a, b = 0, 1\n    for i in range(1, n):\n        a, b = b, a + b\n    print(b)\n#else\n#include <stdio.h>\n#include <stdlib.h>\nint main(int argc, char**argv) {\n    int n = atoi(argv[1]);\n    if (n <= 0) { printf(\"0\\n\"); return 0; }\n    int a = 0, b = 1;\n    for (int i = 1; i < n; i++) { int t = a + b; a = b; b = t; }\n    printf(\"%d\\n\", b);\n    return 0;\n}\n#endif\nPOLYGLOT\n"]
