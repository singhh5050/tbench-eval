[195.605222, "i", "python3 -c \"\nimport socket\nimport subprocess\nimport os\n\n# Check if port is in use\nsock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\nresult = sock.connect_ex(('localhost', 8080))\nif result == 0:\n    print('Port 8080 is open')\nelse:\n    print('Port 8080 is closed')\nsock.close()\n\"\n"]
