[204.646042, "i", "python3 << 'EOF'\nimport os\nimport signal\n\n# Find all pids and check which one is using port 8080\nfor pid in os.listdir('/proc'):\n    if pid.isdigit():\n        try:\n            with open(f'/proc/{pid}/cmdline', 'r') as f:\n                cmdline = f.read()\n                if 'pypi' in cmdline:\n                    print(f'Found pypi process with PID {pid}: {cmdline}')\n                    os.kill(int(pid), signal.SIGKILL)\n        except:\n            pass\nEOF\n"]
[204.646086, "o", "python3 << 'EOF'\r\nimport os\r\nimport signal\r\n\r\n# Find all pids and check which one is using port 8080\r\nfor pid in os.listdir('/proc'):\r\n    if pid.isdigit():\r\n        try:\r\n            with open(f'/proc/{pid}/cmdline', 'r') as f:\r\n                c"]
