import os
import signal

# Find all pids and check which one is using port 8080
for pid in os.listdir('/proc'):
    if pid.isdigit():
        try:
            with open(f'/proc/{pid}/cmdline', 'r') as f:
                cmdline = f.read()
                if 'pypi' in cmdline:
                    print(f'Found pypi process with PID {pid}: {cmdline}')
