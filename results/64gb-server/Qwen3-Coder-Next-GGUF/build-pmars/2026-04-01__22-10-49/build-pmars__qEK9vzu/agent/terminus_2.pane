   as well as the P-space extensions LDP, STP, PIN.
   ******************************************************************** */

/*
#ifndef EXT94
#define EXT94
#endif
*/

/* ********************************************************************
   KEYPRESS: is only useful in conjunction with curses display libraries
   with broken support for interrupt handlers. Define KEYPRESS if you
