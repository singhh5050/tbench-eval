[133.632394, "i", "python3 << 'PYTEST'\nfrom headless_terminal import HeadlessTerminal\nimport time\n\n# Test with a fresh terminal for cleaner output\nprint(\"=== Comprehensive HeadlessTerminal Test ===\")\nterm = HeadlessTerminal()\ntime.sleep(0.5)\n\n# Test basic command with newline\nprint(\"\\nTest: Basic command with newline\")\nterm.send_keystrokes('pwd\\n')\ntime.sleep(0.5)\noutput = term.read_output(timeout=0.5)\nprint(f\"Output contains /app: {'/app' in output}\")\n\n# Test Ctrl+D (exit)\nprint(\"\\nTest: Ctrl+D to exit\")\nterm.send_keystrokes('\\x04')\ntime.sleep(0.5)\n\n# The shell should have exited, let's create a new one\nterm._spawn_interactive_shell()\ntime.sleep(0.5)\nprint(\"Shell respawned successfully\")\n\n# Test Ctrl+C\nprint(\"\\nTest: Ctrl+C with a slow command\")\nterm.send_keystrokes('echo starting\\n')\ntime.sleep(0.3)\nterm.send_keystrokes('read -t 10 x\\x03')\ntime.sleep(0.5)\noutput = term.read_output(timeout=0.5)\nprint(f\"Output after interrupt: {repr(output)}\")\n\n# Test typing a variable name and echo it\nprint(\"\\nTest: Variable assignment and ech"]
[133.632538, "i", "o\")\nterm.send_keystrokes('MYVAR=test\\n')\ntime.sleep(0.3)\nterm.send_keystrokes('echo $MYVAR\\n')\ntime.sleep(0.5)\noutput = term.read_output(timeout=0.5)\nprint(f\"Output: {repr(output)}\")\nprint(f\"Variable test passed: {'test' in output}\")\n\nterm.close()\nprint(\"\\n=== All tests completed successfully! ===\")\nPYTEST\n"]
[133.632571, "o", "python3 << 'PYTEST'\r\n\u001b[?2004l\r\u001b[?2004h> "]
[133.632625, "o", "from headless_terminal import HeadlessTerminal\r\n\u001b[?2004l\r\u001b[?2004h> import time\r\n\u001b[?2004l\r\u001b[?2004h"]
[133.632646, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[133.632683, "o", "# Test with a fresh terminal for cleaner output\r\n\u001b[?2004l\r"]
[133.632697, "o", "\u001b[?2004h> "]
[133.632765, "o", "print(\"=== Comprehensive HeadlessTerminal Test ===\")\r\n\u001b[?2004l\r"]
