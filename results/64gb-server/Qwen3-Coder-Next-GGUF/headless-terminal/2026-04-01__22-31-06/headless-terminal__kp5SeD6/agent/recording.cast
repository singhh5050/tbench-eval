[102.532976, "o", "        env['PS1'] = ''  # Remove prompt to make parsing easier\r\n\u001b[?2004l\r"]
[102.532998, "o", "\u001b[?2004h> "]
[102.53302, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[102.53308, "o", "        # The -i flag makes it interactive, sourcing ~/.bashrc\r\n\u001b[?2004l\r"]
[102.5331, "o", "\u001b[?2004h> "]
[102.533125, "o", "        self.child = pexpect.spawn(\r\n\u001b[?2004l\r"]
[102.533149, "o", "\u001b[?2004h> "]
[102.533171, "o", "            self.shell,\r\n\u001b[?2004l\r"]
[102.533196, "o", "\u001b[?2004h> "]
[102.53322, "o", "            ['-i'],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[102.533246, "o", "            env=env,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[102.533274, "o", "            encoding='utf-8',\r\n\u001b[?2004l\r"]
[102.533301, "o", "\u001b[?2004h> "]
[102.533327, "o", "            timeout=self.timeout\r\n\u001b[?2004l\r\u001b[?2004h> "]
[102.533354, "o", "        )\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[102.533376, "o", "\u001b[?2004h> "]
[102.53341, "o", "        # Give the shell a moment to initialize\r\n\u001b[?2004l\r"]
[102.533432, "o", "\u001b[?2004h> "]
[102.533455, "o", "        try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[102.533489, "o", "            self.child.expect('.*', timeout=1.0)\r\n\u001b[?2004l\r"]
[102.533514, "o", "\u001b[?2004h> "]
[102.533539, "o", "        except pexpect.ExceptionPexpect:\r\n\u001b[?2004l\r"]
[102.533562, "o", "\u001b[?2004h"]
[102.533572, "o", ">             pass\r\n\u001b[?2004l\r"]
[102.533597, "o", "\u001b[?2004h> "]
[102.533619, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[102.533672, "o", "    def send_keystrokes(self, keystrokes: str, wait_sec: float = 0.0) -> None:\r\n\u001b[?2004l\r"]
[102.533695, "o", "\u001b[?2004h> "]
[102.533719, "o", "        \"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[102.533747, "o", "        Sends keystrokes to the terminal.\r\n\u001b[?2004l\r"]
[102.53377, "o", "\u001b[?2004h> "]
[102.533795, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h>         Args:\r\n\u001b[?2004l\r"]
[102.533818, "o", "\u001b[?2004h"]
[102.533844, "o", "> "]
[102.53387, "o", "            keystrokes: The keystrokes to send to the terminal.\r\n\u001b[?2004l\r"]
[102.533894, "o", "\u001b[?2004h> "]
[102.533939, "o", "                Can include regular characters and modifier keys:\r\n\u001b[?2004l\r"]
[102.533962, "o", "\u001b[?2004h> "]
[102.533985, "o", "                - \\x03 for Ctrl+C\r\n\u001b[?2004l\r"]
[102.53401, "o", "\u001b[?2004h> "]
[102.53403, "o", "                - \\x04 for Ctrl+D\r\n\u001b[?2004l\r"]
[102.53406, "o", "\u001b[?2004h> "]
[102.534079, "o", "                - \\x1a for Ctrl+Z\r\n\u001b[?2004l\r"]
[102.534103, "o", "\u001b[?2004h> "]
[102.534121, "o", "                - \\r for Enter\r\n\u001b[?2004l\r"]
[102.534143, "o", "\u001b[?2004h> "]
[102.534162, "o", "                - \\n for newline\r\n\u001b[?2004l\r"]
[102.534184, "o", "\u001b[?2004h> "]
[102.534223, "o", "                - regular characters are typed as-is\r\n\u001b[?2004l\r"]
[102.534246, "o", "\u001b[?2004h> "]
[102.534314, "o", "            wait_sec: The number of seconds to wait for the command to complete.\r\n\u001b[?2004l\r"]
[102.534338, "o", "\u001b[?2004h> "]
[102.534361, "o", "        \"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[102.534379, "o", "        for char in keystrokes:\r\n\u001b[?2004l\r"]
[102.534404, "o", "\u001b[?2004h> "]
[102.534431, "o", "            if char == '\\x03':  # Ctrl+C\r\n\u001b[?2004l\r"]
[102.534451, "o", "\u001b[?2004h> "]
[102.534482, "o", "                self.child.sendcontrol('c')\r\n\u001b[?2004l\r"]
[102.534501, "o", "\u001b[?2004h"]
[102.53451, "o", "> "]
[102.53455, "o", "            elif char == '\\x04':  # Ctrl+D\r\n\u001b[?2004l\r\u001b[?2004h> "]
[102.534592, "o", "                self.child.sendcontrol('d')\r\n\u001b[?2004l\r"]
[102.534613, "o", "\u001b[?2004h> "]
[102.534642, "o", "            elif char == '\\x1a':  # Ctrl+Z\r\n\u001b[?2004l\r"]
[102.534661, "o", "\u001b[?2004h> "]
[102.534692, "o", "                self.child.sendcontrol('z')\r\n\u001b[?2004l\r"]
[102.534713, "o", "\u001b[?2004h> "]
[102.53476, "o", "            elif char == '\\r' or char == '\\n':  # Enter/Return\r\n\u001b[?2004l\r"]
[102.53478, "o", "\u001b[?2004h> "]
[102.534807, "o", "                self.child.sendline('')\r\n\u001b[?2004l\r"]
[102.534829, "o", "\u001b[?2004h> "]
[102.534853, "o", "            elif char == '\\t':  # Tab\r\n\u001b[?2004l\r"]
[102.534874, "o", "\u001b[?2004h> "]
[102.534901, "o", "                self.child.send('\\t')\r\n\u001b[?2004l\r"]
[102.53492, "o", "\u001b[?2004h"]
[102.534943, "o", "> "]
[102.534964, "o", "            elif char == '\\b':  # Backspace\r\n\u001b[?2004l\r"]
[102.534986, "o", "\u001b[?2004h> "]
[102.535008, "o", "                self.child.send('\\b')\r\n\u001b[?2004l\r"]
[102.535031, "o", "\u001b[?2004h> "]
[102.535055, "o", "            elif char == '\\x7f':  # Delete\r\n\u001b[?2004l\r"]
[102.535075, "o", "\u001b[?2004h> "]
[102.535103, "o", "                self.child.sendcontrol('h')\r\n\u001b[?2004l\r"]
[102.535122, "o", "\u001b[?2004h"]
[102.535144, "o", "> "]
[102.535166, "o", "            elif char == '\\x1b':  # Escape\r\n\u001b[?2004l\r"]
[102.535188, "o", "\u001b[?2004h> "]
[102.535208, "o", "                self.child.send('\\x1b')\r\n\u001b[?2004l\r"]
[102.535228, "o", "\u001b[?2004h> "]
[102.535236, "o", "            else:\r\n\u001b[?2004l\r"]
[102.535261, "o", "\u001b[?2004h"]
[102.535284, "o", "> "]
[102.535305, "o", "                # Send regular character\r\n\u001b[?2004l\r\u001b[?2004h> "]
[102.535332, "o", "                self.child.send(char)\r\n\u001b[?2004l\r"]
[102.535352, "o", "\u001b[?2004h> "]
[102.535374, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[102.535394, "o", "        # Wait if specified\r\n\u001b[?2004l\r"]
[102.535415, "o", "\u001b[?2004h"]
[102.535438, "o", ">         if wait_sec > 0:\r\n"]
[102.535459, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[102.535482, "o", "            time.sleep(wait_sec)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[102.535501, "o", "    \r\n"]
[102.535522, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[102.535557, "o", "    def read_output(self, timeout: float = 0.1) -> str:\r\n\u001b[?2004l\r"]
[102.535577, "o", "\u001b[?2004h"]
[102.535598, "o", ">         \"\"\"\r\n\u001b[?2004l\r"]
[102.535621, "o", "\u001b[?2004h> "]
[102.535642, "o", "        Read any available output from the terminal.\r\n\u001b[?2004l\r"]
[102.535663, "o", "\u001b[?2004h> "]
[102.535683, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[102.535703, "o", "        Args:\r\n\u001b[?2004l\r"]
[102.535712, "o", "\u001b[?2004h> "]
[102.535749, "o", "            timeout: Timeout for reading in seconds\r\n\u001b[?2004l\r"]
[102.535769, "o", "\u001b[?2004h"]
[102.53579, "o", ">             \r\n\u001b[?2004l\r"]
[102.535811, "o", "\u001b[?2004h> "]
[102.535822, "o", "        Returns:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[102.535857, "o", "            The output from the terminal\r\n\u001b[?2004l\r"]
[102.535891, "o", "\u001b[?2004h> "]
[102.535919, "o", "        \"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[102.535932, "o", "        self.child.timeout = timeout\r\n\u001b[?2004l\r\u001b[?2004h"]
[102.535945, "o", "> "]
[102.535958, "o", "        try:\r\n\u001b[?2004l\r\u001b[?2004h"]
[102.535969, "o", "> "]
[102.536035, "o", "            output = self.child.read_nonblocking(size=1000, timeout=timeout)\r\n\u001b[?2004l\r"]
[102.536048, "o", "\u001b[?2004h> "]
[102.536094, "o", "            return output if output else ''\r\n\u001b[?2004l\r"]
[102.536108, "o", "\u001b[?2004h> "]
[102.536139, "o", "        except pexpect.TIMEOUT:\r\n\u001b[?2004l\r"]
[102.536152, "o", "\u001b[?2004h> "]
[102.536177, "o", "            return ''\r\n\u001b[?2004l\r"]
[102.536188, "o", "\u001b[?2004h> "]
[102.536218, "o", "        except pexpect.EOF:\r\n\u001b[?2004l\r"]
[102.536232, "o", "\u001b[?2004h> "]
[102.536252, "o", "            return ''\r\n\u001b[?2004l\r"]
[102.536265, "o", "\u001b[?2004h> "]
[102.536278, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[102.536292, "o", "> "]
[102.536314, "o", "    def close(self) -> None:\r\n\u001b[?2004l\r"]
[102.536327, "o", "\u001b[?2004h> "]
[102.536364, "o", "        \"\"\"Close the terminal session.\"\"\"\r\n\u001b[?2004l\r"]
[102.536377, "o", "\u001b[?2004h> "]
[102.536411, "o", "        if self.child is not None:\r\n\u001b[?2004l\r"]
[102.536426, "o", "\u001b[?2004h> "]
[102.536456, "o", "            self.child.close()\r\n\u001b[?2004l\r"]
[102.536468, "o", "\u001b[?2004h> "]
[102.536485, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[102.536497, "o", "> "]
[102.536517, "o", "    def __enter__(self):\r\n\u001b[?2004l\r"]
[102.536531, "o", "\u001b[?2004h> "]
[102.536552, "o", "        return self\r\n\u001b[?2004l\r"]
[102.536566, "o", "\u001b[?2004h> "]
[102.536579, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[102.536591, "o", "> "]
[102.536635, "o", "    def __exit__(self, exc_type, exc_val, exc_tb):\r\n\u001b[?2004l\r"]
[102.536647, "o", "\u001b[?2004h> "]
[102.536669, "o", "        self.close()\r\n\u001b[?2004l\r"]
[102.536682, "o", "\u001b[?2004h> "]
[102.536695, "o", "EOF\r\n\u001b[?2004l\r"]
[102.53762, "o", "\u001b[?2004hroot@c238602e0932:/app# "]
[113.228337, "i", "python3 << 'PYTEST'\nfrom headless_terminal import HeadlessTerminal\nimport time\n\n# Test 1: Basic command execution\nprint(\"Test 1: Basic command execution\")\nterm = HeadlessTerminal()\ntime.sleep(0.5)\n\n# Send 'echo hello' and press Enter\nterm.send_keystrokes('echo hello\\r')\ntime.sleep(0.5)\n\n# Read output\noutput = term.read_output(timeout=0.5)\nprint(f\"Output: {repr(output)}\")\n\n# Test 2: Ctrl+C\nprint(\"\\nTest 2: Sending Ctrl+C\")\nterm.send_keystrokes('sleep 10\\x03')\ntime.sleep(0.5)\noutput = term.read_output(timeout=0.5)\nprint(f\"Output after Ctrl+C: {repr(output)}\")\n\n# Test 3: Test that bashrc was sourced (check if prompt is set)\nprint(\"\\nTest 3: Checking bashrc was sourced\")\nterm.send_keystrokes('echo $PS1\\r')\ntime.sleep(0.5)\noutput = term.read_output(timeout=0.5)\nprint(f\"PS1 output: {repr(output)}\")\n\nterm.close()\nprint(\"\\nAll tests passed!\")\nPYTEST\n"]
