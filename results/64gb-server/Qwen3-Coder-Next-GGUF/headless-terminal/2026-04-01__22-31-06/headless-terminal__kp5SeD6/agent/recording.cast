[102.531523, "i", "cat > /app/headless_terminal.py << 'EOF'\nimport pexpect\nimport os\nimport time\nfrom base_terminal import BaseTerminal\n\n\nclass HeadlessTerminal(BaseTerminal):\n    \"\"\"A headless terminal implementation using pexpect.\"\"\"\n    \n    def __init__(self, shell: str = \"bash\", timeout: float = 30.0):\n        \"\"\"\n        Initialize the headless terminal with an interactive bash shell.\n        \n        Args:\n            shell: The shell to use (default: bash)\n            timeout: Timeout for operations in seconds\n        \"\"\"\n        self.shell = shell\n        self.timeout = timeout\n        self.child = None\n        self._spawn_interactive_shell()\n    \n    def _spawn_interactive_shell(self):\n        \"\"\"Spawn an interactive bash shell that sources startup files.\"\"\"\n        # Use -i for interactive mode which sources ~/.bashrc\n        # Set TERM to a valid terminal type to avoid issues\n        env = os.environ.copy()\n        env['TERM'] = 'xterm'\n        env['PS1'] = ''  # Remove prompt to make parsing easier\n        \n       "]
[102.53177, "i", " # The -i flag makes it interactive, sourcing ~/.bashrc\n        self.child = pexpect.spawn(\n            self.shell,\n            ['-i'],\n            env=env,\n            encoding='utf-8',\n            timeout=self.timeout\n        )\n        \n        # Give the shell a moment to initialize\n        try:\n            self.child.expect('.*', timeout=1.0)\n        except pexpect.ExceptionPexpect:\n            pass\n    \n    def send_keystrokes(self, keystrokes: str, wait_sec: float = 0.0) -> None:\n        \"\"\"\n        Sends keystrokes to the terminal.\n        \n        Args:\n            keystrokes: The keystrokes to send to the terminal.\n                Can include regular characters and modifier keys:\n                - \\x03 for Ctrl+C\n                - \\x04 for Ctrl+D\n                - \\x1a for Ctrl+Z\n                - \\r for Enter\n                - \\n for newline\n                - regular characters are typed as-is\n            wait_sec: The number of seconds to wait for the command to complete.\n        \"\"\"\n        for ch"]
[102.531825, "o", "cat > /app/headless_terminal.py << 'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> import pexpect\r\n\u001b[?2004l\r\u001b[?2004h> import os\r\n\u001b[?2004l\r\u001b[?2004h> import time\r\n\u001b[?2004l\r\u001b[?2004h> from base_terminal import BaseTerminal\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[102.531848, "i", "ar in keystrokes:\n            if char == '\\x03':  # Ctrl+C\n                self.child.sendcontrol('c')\n            elif char == '\\x04':  # Ctrl+D\n                self.child.sendcontrol('d')\n            elif char == '\\x1a':  # Ctrl+Z\n                self.child.sendcontrol('z')\n            elif char == '\\r' or char == '\\n':  # Enter/Return\n                self.child.sendline('')\n            elif char == '\\t':  # Tab\n                self.child.send('\\t')\n            elif char == '\\b':  # Backspace\n                self.child.send('\\b')\n            elif char == '\\x7f':  # Delete\n                self.child.sendcontrol('h')\n            elif char == '\\x1b':  # Escape\n                self.child.send('\\x1b')\n            else:\n                # Send regular character\n                self.child.send(char)\n        \n        # Wait if specified\n        if wait_sec > 0:\n            time.sleep(wait_sec)\n    \n    def read_output(self, timeout: float = 0.1) -> str:\n        \"\"\"\n        Read any available output from the terminal"]
[102.531874, "o", "\u001b[?2004h> class HeadlessTerminal(BaseTerminal):\r\n\u001b[?2004l\r"]
