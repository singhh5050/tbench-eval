[130.833016, "i", "python3 << 'EOF'\nimport hashlib\n\n# Read the image bytes\nwith open('/app/code.png', 'rb') as f:\n    img_bytes = f.read()\n\n# Step 1: Compute SHA256 of the image bytes\nh0 = hashlib.sha256(img_bytes).digest()\n\n# Try different salt values\nsalts = [\n    b'0000TBENCH-SALT',\n    b'6\\'0000TBENCH-SALT\"',\n    b'0000TBENCH-SALT\"',\n]\n\nfor salt in salts:\n    # Try different constructions\n    h1 = h0[:10] + salt\n    H = hashlib.sha256(h1).hexdigest()\n    print(f\"h0[:10] + salt: {H}\")\n    \n    h2 = h0 + salt\n    H2 = hashlib.sha256(h2).hexdigest()\n    print(f\"h0 + salt: {H2}\")\n    \n    h3 = h0 + h0[:10] + salt\n    H3 = hashlib.sha256(h3).hexdigest()\n    print(f\"h0 + h0[:10] + salt: {H3}\")\n    print()\nEOF\n"]
