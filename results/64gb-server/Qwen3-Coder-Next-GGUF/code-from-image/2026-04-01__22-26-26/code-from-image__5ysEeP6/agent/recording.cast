[106.369938, "i", "python3 << 'EOF'\nfrom PIL import Image\nimport pytesseract\n\n# Try different OCR configurations\nimg = Image.open('/app/code.png')\n\n# Try with psm mode for single block\ntext = pytesseract.image_to_string(img, config='--psm 6')\nprint(\"PSM 6:\", repr(text))\n\n# Try with psm 11 (sparse text)\ntext2 = pytesseract.image_to_string(img, config='--psm 11')\nprint(\"PSM 11:\", repr(text2))\nEOF\n"]
