[549.281275, "i", "             (set-cdr! (car frame) val)\n                (loop (cdr e)))))))\n\n;; ---------- Closure representation ----------\n(define (make-closure params body env) (list 'closure params body env))\n(define (closure? obj) (and (pair? obj) (eq? (car obj) 'closure)))\n(define (closure-params clo) (cadr clo))\n(define (closure-body clo) (caddr clo))\n(define (closure-env clo) (cadddr clo))\n\n;; ---------- Evaluator ----------\n(define (my-eval exp env)\n  (cond\n    ;; literals\n    ((or (number? exp) (string? exp) (boolean? exp)) exp)\n    ;; variable reference\n    ((symbol? exp) (or (env-lookup exp env) exp))\n    ;; special forms and application\n    ((pair? exp)\n     (let ((op (car exp)))\n       (cond\n         ((eq? op 'quote) (cadr exp))\n         ((eq? op 'if)\n          (let ((test (cadr exp))\n                (conseq (caddr exp))\n                (alt (cadddr exp)))\n            (if (my-eval test env) (my-eval conseq env) (my-eval alt env))))\n         ((eq? op 'define)\n          (let ((target (cadr exp))\n                ("]
