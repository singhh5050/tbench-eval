[395.06832, "o", "  (let ((new-frame (let build ((vs vars) (vs2 vals) (f (make-frame)))\r\n\u001b[?2004l\r\u001b[?2004h"]
[395.068348, "o", "> "]
[395.068381, "o", "                     (if (null? vs) f\r\n\u001b[?2004l\r"]
[395.0684, "o", "\u001b[?2004h> "]
[395.068514, "o", "                         (build (cdr vs) (cdr vs2) (frame-extend (car vs) (car vs2) f)))))\r\n\u001b[?2004l\r"]
[395.06853, "o", "\u001b[?2004h> "]
[395.068563, "o", "    (cons new-frame env)))\r\n\u001b[?2004l\r"]
[395.068578, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[395.068596, "o", "\u001b[?2004h> "]
[395.068634, "o", "(define (env-set! var val env)\r\n\u001b[?2004l\r\u001b[?2004h"]
[395.068667, "o", "> "]
[395.06869, "o", "  (let loop ((e env))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[395.068778, "o", "    (if (null? e) (error \"unbound variable\" var)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[395.068889, "o", "        (let ((frame (car e)))\r\n\u001b[?2004l\r\u001b[?2004h>           (let ((pair (frame-lookup var frame)))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[395.068941, "o", "            (if pair\r\n\u001b[?2004l\r\u001b[?2004h> "]
[395.068996, "o", "                (set-cdr! (car frame) val)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[395.069059, "o", "                (loop (cdr e)))))))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[395.069101, "o", ";; ---------- Closure representation ----------\r\n\u001b[?2004l\r\u001b[?2004h> "]
[395.069169, "o", "(define (make-closure params body env) (list 'closure params body env))\r\n\u001b[?2004l\r"]
[395.069185, "o", "\u001b[?2004h> "]
[395.069253, "o", "(define (closure? obj) (and (pair? obj) (eq? (car obj) 'closure)))\r\n\u001b[?2004l\r\u001b[?2004h"]
[395.06928, "o", "> "]
[395.069298, "o", "(define (closure-params clo) (cadr clo))\r\n\u001b[?2004l\r\u001b[?2004h"]
[395.069312, "o", "> "]
[395.069336, "o", "(define (closure-body clo) (caddr clo))\r\n\u001b[?2004l\r"]
[395.06935, "o", "\u001b[?2004h> "]
[395.069382, "o", "(define (closure-env clo) (cadddr clo))\r\n\u001b[?2004l\r"]
[395.069393, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[395.069407, "o", "\u001b[?2004h> "]
[395.069437, "o", ";; ---------- Evaluator ----------\r\n\u001b[?2004l\r"]
[395.069451, "o", "\u001b[?2004h> "]
[395.069471, "o", "(define (my-eval exp env)\r\n\u001b[?2004l\r"]
[395.069484, "o", "\u001b[?2004h> "]
[395.069498, "o", "  (cond\r\n\u001b[?2004l\r\u001b[?2004h> "]
[395.069514, "o", "    ;; literals\r\n\u001b[?2004l\r"]
[395.069527, "o", "\u001b[?2004h> "]
[395.069576, "o", "    ((or (number? exp) (string? exp) (boolean? exp)) exp)\r\n\u001b[?2004l\r"]
[395.06959, "o", "\u001b[?2004h> "]
[395.069611, "o", "    ;; variable reference\r\n\u001b[?2004l\r"]
[395.069624, "o", "\u001b[?2004h> "]
[395.069671, "o", "    ((symbol? exp) (or (env-lookup exp env) exp))\r\n\u001b[?2004l\r"]
[395.069682, "o", "\u001b[?2004h> "]
[395.069715, "o", "    ;; special forms and application\r\n\u001b[?2004l\r"]
[395.069728, "o", "\u001b[?2004h> "]
[395.06974, "o", "    ((pair? exp)\r\n\u001b[?2004l\r"]
[395.069752, "o", "\u001b[?2004h> "]
[395.069776, "o", "     (let ((op (car exp)))\r\n\u001b[?2004l\r"]
[395.069789, "o", "\u001b[?2004h> "]
[395.069801, "o", "       (cond\r\n\u001b[?2004l\r"]
[395.069813, "o", "\u001b[?2004h> "]
[395.069844, "o", "         ((eq? op 'quote) (cadr exp))\r\n\u001b[?2004l\r"]
[395.069857, "o", "\u001b[?2004h> "]
[395.069874, "o", "         ((eq? op 'if)\r\n\u001b[?2004l\r"]
[395.069888, "o", "\u001b[?2004h> "]
[395.069916, "o", "          (let ((test (cadr exp))\r\n\u001b[?2004l\r"]
[395.069929, "o", "\u001b[?2004h> "]
[395.069959, "o", "                (conseq (caddr exp))\r\n\u001b[?2004l\r"]
[395.069972, "o", "\u001b[?2004h> "]
[395.070002, "o", "                (alt (cadddr exp)))\r\n\u001b[?2004l\r"]
[395.070015, "o", "\u001b[?2004h> "]
[395.07008, "o", "            (if (my-eval test env) (my-eval conseq env) (my-eval alt env))))\r\n\u001b[?2004l\r"]
[395.070093, "o", "\u001b[?2004h> "]
[395.070117, "o", "         ((eq? op 'define)\r\n\u001b[?2004l\r"]
[395.070129, "o", "\u001b[?2004h> "]
[395.070158, "o", "          (let ((target (cadr exp))\r\n\u001b[?2004l\r"]
[395.07017, "o", "\u001b[?2004h> "]
[395.070205, "o", "                (value-expr (caddr exp)))\r\n\u001b[?2004l\r"]
[395.070217, "o", "\u001b[?2004h> "]
[395.070245, "o", "            (if (pair? target)\r\n\u001b[?2004l\r"]
[395.070256, "o", "\u001b[?2004h> "]
[395.07029, "o", "                ;; function shorthand\r\n\u001b[?2004l\r"]
[395.070304, "o", "\u001b[?2004h> "]
[395.07034, "o", "                (let ((fname (car target))\r\n\u001b[?2004l\r"]
[395.070353, "o", "\u001b[?2004h> "]
[395.07039, "o", "                      (params (cdr target))\r\n\u001b[?2004l\r"]
[395.070402, "o", "\u001b[?2004h> "]
[395.070436, "o", "                      (body (cddr exp)))\r\n\u001b[?2004l\r"]
[395.070448, "o", "\u001b[?2004h> "]
[395.070521, "o", "                  (env-extend (list fname) (list (make-closure params body env)) env)\r\n\u001b[?2004l\r"]
[395.070535, "o", "\u001b[?2004h> "]
[395.070554, "o", "                  'ok)\r\n\u001b[?2004l\r"]
[395.070565, "o", "\u001b[?2004h> "]
[395.070611, "o", "                (let ((val (my-eval value-expr env)))\r\n\u001b[?2004l\r"]
[395.070624, "o", "\u001b[?2004h> "]
[395.070664, "o", "                  (env-set! target val env)\r\n\u001b[?2004l\r"]
[395.070679, "o", "\u001b[?2004h"]
[395.070691, "o", "> "]
[395.070704, "o", "                  'ok))))\r\n\u001b[?2004l\r"]
[395.070717, "o", "\u001b[?2004h> "]
[395.070734, "o", "         ((eq? op 'set!)\r\n\u001b[?2004l\r"]
[395.070746, "o", "\u001b[?2004h> "]
[395.070794, "o", "          (let ((var (cadr exp)) (val-expr (caddr exp)))\r\n\u001b[?2004l\r"]
[395.070806, "o", "\u001b[?2004h> "]
[395.070852, "o", "            (env-set! var (my-eval val-expr env) env)\r\n\u001b[?2004l\r"]
[395.070865, "o", "\u001b[?2004h> "]
[395.070879, "o", "            'ok))\r\n\u001b[?2004l\r"]
[395.070892, "o", "\u001b[?2004h> "]
[395.070914, "o", "         ((eq? op 'lambda)\r\n\u001b[?2004l\r"]
[395.070931, "o", "\u001b[?2004h> "]
[395.070971, "o", "          (make-closure (cadr exp) (cddr exp) env))\r\n\u001b[?2004l\r"]
[395.070984, "o", "\u001b[?2004h> "]
[395.071004, "o", "         ((eq? op 'let)\r\n\u001b[?2004l\r"]
[395.071017, "o", "\u001b[?2004h> "]
[395.071049, "o", "          (let ((bindings (cadr exp))\r\n\u001b[?2004l\r"]
[395.071062, "o", "\u001b[?2004h> "]
[395.071091, "o", "                (body (cddr exp)))\r\n\u001b[?2004l\r"]
[395.071104, "o", "\u001b[?2004h> "]
[395.071139, "o", "            (let ((vars '()) (vals '()))\r\n\u001b[?2004l\r"]
[395.071152, "o", "\u001b[?2004h> "]
[395.071183, "o", "              (let loop ((b bindings))\r\n\u001b[?2004l\r"]
[395.071195, "o", "\u001b[?2004h> "]
[395.071224, "o", "                (if (null? b) #t\r\n\u001b[?2004l\r"]
[395.071236, "o", "\u001b[?2004h> "]
[395.071259, "o", "                    (begin\r\n\u001b[?2004l\r"]
[395.071273, "o", "\u001b[?2004h> "]
[395.071322, "o", "                      (set! vars (cons (car (car b)) vars))\r\n\u001b[?2004l\r"]
[395.071337, "o", "\u001b[?2004h> "]
[395.071398, "o", "                      (set! vals (cons (my-eval (cadr (car b)) env) vals))\r\n\u001b[?2004l\r"]
[395.071412, "o", "\u001b[?2004h> "]
[395.071445, "o", "                      (loop (cdr b)))))\r\n\u001b[?2004l\r"]
[395.071458, "o", "\u001b[?2004h> "]
[395.071537, "o", "              (my-eval (cons 'begin body) (env-extend (reverse vars) (reverse vals) env)))))\r\n\u001b[?2004l\r"]
[395.07155, "o", "\u001b[?2004h> "]
[395.071573, "o", "         ((eq? op 'begin)\r\n\u001b[?2004l\r"]
[395.071585, "o", "\u001b[?2004h> "]
[395.071627, "o", "          (let loop ((exps (cdr exp)) (result '()))\r\n\u001b[?2004l\r"]
[395.071639, "o", "\u001b[?2004h> "]
[395.071676, "o", "            (if (null? exps) result\r\n\u001b[?2004l\r"]
[395.07169, "o", "\u001b[?2004h> "]
[395.071741, "o", "                (loop (cdr exps) (my-eval (car exps) env)))))\r\n\u001b[?2004l\r"]
[395.071754, "o", "\u001b[?2004h> "]
[395.071776, "o", "         ((eq? op 'cond)\r\n\u001b[?2004l\r"]
[395.071788, "o", "\u001b[?2004h> "]
[395.071828, "o", "          (let cond-loop ((clauses (cdr exp)))\r\n\u001b[?2004l\r"]
[395.071841, "o", "\u001b[?2004h> "]
[395.07187, "o", "            (if (null? clauses) #f\r\n\u001b[?2004l\r"]
[395.071883, "o", "\u001b[?2004h> "]
[395.071918, "o", "                (let ((cl (car clauses)))\r\n\u001b[?2004l\r"]
[395.071931, "o", "\u001b[?2004h> "]
[395.07198, "o", "                  (let ((test (car cl)) (body (cdr cl)))\r\n\u001b[?2004l\r"]
[395.071996, "o", "\u001b[?2004h> "]
[395.072055, "o", "                    (if (or (eq? test 'else) (my-eval test env))\r\n\u001b[?2004l\r"]
[395.072071, "o", "\u001b[?2004h> "]
[395.072125, "o", "                        (let seq-loop ((es body) (res #f))\r\n\u001b[?2004l\r"]
[395.072139, "o", "\u001b[?2004h> "]
[395.072176, "o", "                          (if (null? es) res\r\n\u001b[?2004l\r"]
[395.072187, "o", "\u001b[?2004h> "]
[395.072252, "o", "                              (seq-loop (cdr es) (my-eval (car es) env))))\r\n\u001b[?2004l\r"]
[395.072264, "o", "\u001b[?2004h> "]
[395.072312, "o", "                        (cond-loop (cdr clauses)))))))\r\n\u001b[?2004l\r"]
[395.072324, "o", "\u001b[?2004h> "]
[395.072356, "o", "         (else ; procedure application\r\n\u001b[?2004l\r"]
[395.07237, "o", "\u001b[?2004h> "]
[395.072402, "o", "          (my-apply (my-eval op env)\r\n\u001b[?2004l\r"]
[395.072415, "o", "\u001b[?2004h> "]
[395.072476, "o", "                    (map (lambda (arg) (my-eval arg env)) (cdr exp)))))))\r\n\u001b[?2004l\r"]
[395.072489, "o", "\u001b[?2004h> "]
[395.072532, "o", "    (else (error \"unknown expression type\" exp))))\r\n\u001b[?2004l\r"]
[395.072546, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[395.072559, "o", "\u001b[?2004h> "]
[395.072597, "o", ";; ---------- Procedure application ----------\r\n\u001b[?2004l\r"]
[395.072609, "o", "\u001b[?2004h> "]
[395.072632, "o", "(define (my-apply proc args)\r\n\u001b[?2004l\r"]
[395.072644, "o", "\u001b[?2004h> "]
[395.072659, "o", "  (cond\r\n\u001b[?2004l\r"]
[395.072672, "o", "\u001b[?2004h> "]
[395.072707, "o", "    ((procedure? proc) (apply proc args))\r\n\u001b[?2004l\r"]
[395.072719, "o", "\u001b[?2004h> "]
[395.072737, "o", "    ((closure? proc)\r\n\u001b[?2004l\r"]
[395.072749, "o", "\u001b[?2004h> "]
[395.072819, "o", "     (let ((new-env (env-extend (closure-params proc) args (closure-env proc))))\r\n\u001b[?2004l\r"]
[395.072833, "o", "\u001b[?2004h> "]
[395.072883, "o", "       (my-eval (cons 'begin (closure-body proc)) new-env)))\r\n\u001b[?2004l\r"]
[395.072896, "o", "\u001b[?2004h> "]
[395.072933, "o", "    (else (error \"not a procedure\" proc))))\r\n\u001b[?2004l\r"]
[395.072947, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[395.07296, "o", "\u001b[?2004h> "]
[395.072985, "o", ";; ---------- Driver ----------\r\n\u001b[?2004l\r"]
[395.072998, "o", "\u001b[?2004h> "]
[395.07304, "o", ";; Read the path of the program file (first line)\r\n\u001b[?2004l\r"]
[395.073053, "o", "\u001b[?2004h> "]
[395.073076, "o", "(define file-path (read))\r\n\u001b[?2004l\r"]
[395.07309, "o", "\u001b[?2004h> "]
[395.073122, "o", ";; Open the program file for reading\r\n\u001b[?2004l\r"]
[395.073133, "o", "\u001b[?2004h> "]
[395.073166, "o", "(define fid (fopen file-path \"r\"))\r\n\u001b[?2004l\r"]
[395.073178, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[395.07319, "o", "\u001b[?2004h> "]
[395.073225, "o", ";; Evaluate each expression from the file\r\n\u001b[?2004l\r"]
[395.073239, "o", "\u001b[?2004h> "]
[395.073262, "o", "(define (eval-file fid env)\r\n\u001b[?2004l\r"]
[395.073274, "o", "\u001b[?2004h> "]
[395.073288, "o", "  (let loop ()\r\n\u001b[?2004l\r"]
[395.0733, "o", "\u001b[?2004h> "]
[395.073326, "o", "    (let ((expr (fread fid)))\r\n\u001b[?2004l\r"]
[395.073336, "o", "\u001b[?2004h> "]
[395.073375, "o", "      (if (or (eq? expr #f) (eq? expr None))\r\n\u001b[?2004l\r"]
[395.073388, "o", "\u001b[?2004h> "]
[395.07342, "o", "          (begin (fclose fid) 'done)\r\n\u001b[?2004l\r"]
[395.073432, "o", "\u001b[?2004h"]
[395.073444, "o", "> "]
[395.073472, "o", "          (begin (my-eval expr env) (loop))))))\r\n\u001b[?2004l\r"]
[395.073484, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[395.073496, "o", "\u001b[?2004h> "]
[395.073519, "o", "(eval-file fid global-env)\r\n\u001b[?2004l\r"]
[395.073531, "o", "\u001b[?2004h"]
[395.073544, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[395.073572, "o", ";; REPL for remaining stdin input\r\n\u001b[?2004l\r"]
[395.073585, "o", "\u001b[?2004h> "]
[395.073595, "o", "(let repl ()\r\n\u001b[?2004l\r"]
[395.073608, "o", "\u001b[?2004h> "]
[395.073627, "o", "  (let ((expr (read)))\r\n\u001b[?2004l\r"]
[395.073639, "o", "\u001b[?2004h> "]
[395.07368, "o", "    (if (or (eq? expr #f) (eq? expr None))\r\n\u001b[?2004l\r"]
[395.073692, "o", "\u001b[?2004h"]
[395.073704, "o", ">         (void)\r\n"]
[395.073715, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[395.07373, "o", "        (begin\r\n\u001b[?2004l\r"]
[395.073742, "o", "\u001b[?2004h> "]
[395.073788, "o", "          (let ((result (my-eval expr global-env)))\r\n\u001b[?2004l\r"]
[395.073801, "o", "\u001b[?2004h> "]
[395.073834, "o", "            (display result) (newline))\r\n\u001b[?2004l\r"]
[395.073845, "o", "\u001b[?2004h> "]
[395.073867, "o", "          (repl)))))\r\n\u001b[?2004l\r"]
[395.07388, "o", "\u001b[?2004h> EOF\r\n"]
[395.073892, "o", "\u001b[?2004l\r"]
[395.074862, "o", "\u001b[?2004h"]
[395.074876, "o", "root@499f5d5c5564:/app# "]
[398.064855, "i", "chmod +x eval.scm\n"]
[398.065027, "o", "chmod +x eval.scm\r\n\u001b[?2004l\r"]
[398.066254, "o", "\u001b[?2004h"]
[398.06631, "o", "root@499f5d5c5564:/app# "]
[398.162306, "i", "echo '(+ 7 8)' | python3 interp.py eval.scm\n"]
[398.162383, "o", "echo '(+ 7 8)' | python3 interp.py eval.scm\r\n"]
[398.162391, "o", "\u001b[?2004l\r"]
[398.175268, "o", "Error: Missing closing parenthesis\r\n"]
[398.177052, "o", "\u001b[?2004hroot@499f5d5c5564:/app# "]
[467.520093, "i", "rm -f eval.scm\n"]
[467.520241, "o", "rm -f eval.scm\r\n\u001b[?2004l\r"]
