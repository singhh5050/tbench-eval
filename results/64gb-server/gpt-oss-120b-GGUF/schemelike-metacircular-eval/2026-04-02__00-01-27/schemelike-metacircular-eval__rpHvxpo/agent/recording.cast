[549.284332, "o", "\u001b[?2004h> "]
[549.284356, "o", "            (if (pair? target)\r\n\u001b[?2004l\r"]
[549.284369, "o", "\u001b[?2004h> "]
[549.2844, "o", "                ;; function shorthand\r\n\u001b[?2004l\r"]
[549.284412, "o", "\u001b[?2004h> "]
[549.284449, "o", "                (let ((fname (car target))\r\n\u001b[?2004l\r"]
[549.284471, "o", "\u001b[?2004h> "]
[549.2845, "o", "                      (params (cdr target))\r\n\u001b[?2004l\r"]
[549.284513, "o", "\u001b[?2004h> "]
[549.284545, "o", "                      (body (cddr exp)))\r\n\u001b[?2004l\r"]
[549.284556, "o", "\u001b[?2004h> "]
[549.28463, "o", "                  (env-extend (list fname) (list (make-closure params body env)) env)\r\n\u001b[?2004l\r"]
[549.284643, "o", "\u001b[?2004h> "]
[549.284668, "o", "                  'ok)\r\n\u001b[?2004l\r"]
[549.284678, "o", "\u001b[?2004h> "]
[549.284726, "o", "                (let ((val (my-eval value-expr env)))\r\n\u001b[?2004l\r"]
[549.284738, "o", "\u001b[?2004h> "]
[549.284775, "o", "                  (env-set! target val env)\r\n\u001b[?2004l\r"]
[549.284785, "o", "\u001b[?2004h> "]
[549.28481, "o", "                  'ok))))\r\n\u001b[?2004l\r"]
[549.284824, "o", "\u001b[?2004h> "]
[549.284844, "o", "         ((eq? op 'set!)\r\n\u001b[?2004l\r"]
[549.284856, "o", "\u001b[?2004h> "]
[549.284904, "o", "          (let ((var (cadr exp)) (val-expr (caddr exp)))\r\n\u001b[?2004l\r"]
[549.284917, "o", "\u001b[?2004h> "]
[549.284963, "o", "            (env-set! var (my-eval val-expr env) env)\r\n\u001b[?2004l\r"]
[549.284974, "o", "\u001b[?2004h> "]
[549.28499, "o", "            'ok))\r\n\u001b[?2004l\r"]
[549.285002, "o", "\u001b[?2004h> "]
[549.285026, "o", "         ((eq? op 'lambda)\r\n\u001b[?2004l\r"]
[549.285038, "o", "\u001b[?2004h> "]
[549.285083, "o", "          (make-closure (cadr exp) (cddr exp) env))\r\n\u001b[?2004l\r"]
[549.285095, "o", "\u001b[?2004h> "]
[549.285116, "o", "         ((eq? op 'let)\r\n\u001b[?2004l\r"]
[549.285128, "o", "\u001b[?2004h> "]
[549.285161, "o", "          (let ((bindings (cadr exp))\r\n\u001b[?2004l\r"]
[549.285173, "o", "\u001b[?2004h> "]
[549.285203, "o", "                (body (cddr exp)))\r\n\u001b[?2004l\r"]
[549.285215, "o", "\u001b[?2004h> "]
[549.285251, "o", "            (let ((vars '()) (vals '()))\r\n\u001b[?2004l\r"]
[549.285262, "o", "\u001b[?2004h> "]
[549.285296, "o", "              (let loop ((b bindings))\r\n\u001b[?2004l\r"]
[549.285306, "o", "\u001b[?2004h> "]
[549.285337, "o", "                (if (null? b) #t\r\n\u001b[?2004l\r"]
[549.285348, "o", "\u001b[?2004h> "]
[549.285372, "o", "                    (begin\r\n\u001b[?2004l\r"]
[549.285385, "o", "\u001b[?2004h> "]
[549.285435, "o", "                      (set! vars (cons (car (car b)) vars))\r\n\u001b[?2004l\r"]
[549.285448, "o", "\u001b[?2004h> "]
[549.285511, "o", "                      (set! vals (cons (my-eval (cadr (car b)) env) vals))\r\n\u001b[?2004l\r"]
[549.285525, "o", "\u001b[?2004h> "]
[549.285558, "o", "                      (loop (cdr b)))))\r\n\u001b[?2004l\r"]
[549.285569, "o", "\u001b[?2004h> "]
[549.285656, "o", "              (my-eval (cons 'begin body) (env-extend (reverse vars) (reverse vals) env)))))\r\n\u001b[?2004l\r"]
[549.285687, "o", "\u001b[?2004h"]
[549.285699, "o", "> "]
[549.285723, "o", "         ((eq? op 'begin)\r\n\u001b[?2004l\r"]
[549.285735, "o", "\u001b[?2004h> "]
[549.285783, "o", "          (let loop ((exps (cdr exp)) (result '()))\r\n\u001b[?2004l\r"]
[549.285794, "o", "\u001b[?2004h> "]
[549.285827, "o", "            (if (null? exps) result\r\n\u001b[?2004l\r"]
[549.28584, "o", "\u001b[?2004h> "]
[549.285893, "o", "                (loop (cdr exps) (my-eval (car exps) env)))))\r\n\u001b[?2004l\r"]
[549.285904, "o", "\u001b[?2004h> "]
[549.285929, "o", "         ((eq? op 'cond)\r\n\u001b[?2004l\r"]
[549.285941, "o", "\u001b[?2004h> "]
[549.285982, "o", "          (let cond-loop ((clauses (cdr exp)))\r\n\u001b[?2004l\r"]
[549.285994, "o", "\u001b[?2004h> "]
[549.286025, "o", "            (if (null? clauses) #f\r\n\u001b[?2004l\r"]
[549.286037, "o", "\u001b[?2004h> "]
[549.286072, "o", "                (let ((cl (car clauses)))\r\n\u001b[?2004l\r"]
[549.286083, "o", "\u001b[?2004h> "]
[549.286134, "o", "                  (let ((test (car cl)) (body (cdr cl)))\r\n\u001b[?2004l\r"]
[549.286145, "o", "\u001b[?2004h> "]
[549.286204, "o", "                    (if (or (eq? test 'else) (my-eval test env))\r\n\u001b[?2004l\r"]
[549.286217, "o", "\u001b[?2004h> "]
[549.286268, "o", "                        (let seq-loop ((es body) (res #f))\r\n\u001b[?2004l\r"]
[549.286291, "o", "\u001b[?2004h> "]
[549.286318, "o", "                          (if (null? es) res\r\n\u001b[?2004l\r"]
[549.28633, "o", "\u001b[?2004h> "]
[549.286395, "o", "                              (seq-loop (cdr es) (my-eval (car es) env))))\r\n\u001b[?2004l\r"]
[549.286409, "o", "\u001b[?2004h> "]
[549.286454, "o", "                        (cond-loop (cdr clauses)))))))\r\n\u001b[?2004l\r"]
[549.286467, "o", "\u001b[?2004h> "]
[549.2865, "o", "         (else ; procedure application\r\n\u001b[?2004l\r"]
[549.286511, "o", "\u001b[?2004h"]
[549.286522, "o", "> "]
[549.286564, "o", "          (my-apply (my-eval op env)\r\n"]
[549.286576, "o", "\u001b[?2004l\r\u001b[?2004h"]
[549.286587, "o", "> "]
[549.286688, "o", "                    (map (lambda (arg) (my-eval arg env)) (cdr exp)))))))\r\n\u001b[?2004l\r"]
[549.2867, "o", "\u001b[?2004h> "]
[549.286829, "o", "    (else (error \"unknown expression type\" exp))))\r\n"]
[549.286842, "o", "\u001b[?2004l\r"]
[549.286878, "o", "\u001b[?2004h"]
[549.286892, "o", "> \r\n\u001b[?2004l\r"]
[549.28691, "o", "\u001b[?2004h> "]
[549.287, "o", ";; ---------- Procedure application ----------\r\n"]
[549.287012, "o", "\u001b[?2004l\r"]
[549.287026, "o", "\u001b[?2004h> "]
[549.287082, "o", "(define (my-apply proc args)\r\n\u001b[?2004l\r"]
[549.287098, "o", "\u001b[?2004h"]
[549.287111, "o", "> "]
[549.287124, "o", "  (cond\r\n\u001b[?2004l\r"]
[549.28714, "o", "\u001b[?2004h> "]
[549.28722, "o", "    ((procedure? proc) (apply proc args))\r\n\u001b[?2004l\r"]
[549.287236, "o", "\u001b[?2004h> "]
[549.287281, "o", "    ((closure? proc)\r\n\u001b[?2004l\r"]
[549.287298, "o", "\u001b[?2004h> "]
[549.287388, "o", "     (let ((new-env (env-extend (closure-params proc) args (closure-env proc))))\r\n\u001b[?2004l\r"]
[549.2874, "o", "\u001b[?2004h> "]
[549.287455, "o", "       (my-eval (cons 'begin (closure-body proc)) new-env)))\r\n\u001b[?2004l\r"]
[549.287467, "o", "\u001b[?2004h> "]
[549.287507, "o", "    (else (error \"not a procedure\" proc))))\r\n\u001b[?2004l\r"]
[549.287521, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[549.287532, "o", "\u001b[?2004h> "]
[549.287561, "o", ";; ---------- Driver ----------\r\n\u001b[?2004l\r"]
[549.287575, "o", "\u001b[?2004h> "]
[549.287617, "o", ";; Read the path of the program file (first line)\r\n\u001b[?2004l\r"]
[549.287632, "o", "\u001b[?2004h> "]
[549.287683, "o", "(define file-path (read))\r\n"]
[549.287698, "o", "\u001b[?2004l\r"]
[549.287712, "o", "\u001b[?2004h> "]
[549.287753, "o", ";; Open the program file for reading\r\n\u001b[?2004l\r"]
[549.287766, "o", "\u001b[?2004h> "]
[549.2878, "o", "(define fid (fopen file-path \"r\"))\r\n\u001b[?2004l\r"]
[549.287815, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[549.287827, "o", "\u001b[?2004h> "]
[549.287865, "o", ";; Evaluate each expression from the file\r\n\u001b[?2004l\r"]
[549.287878, "o", "\u001b[?2004h> "]
[549.287904, "o", "(define (eval-file fid env)\r\n\u001b[?2004l\r"]
[549.287916, "o", "\u001b[?2004h> "]
[549.287932, "o", "  (let loop ()\r\n\u001b[?2004l\r"]
[549.287944, "o", "\u001b[?2004h> "]
[549.287971, "o", "    (let ((expr (fread fid)))\r\n\u001b[?2004l\r"]
[549.287983, "o", "\u001b[?2004h> "]
[549.288023, "o", "      (if (or (eq? expr #f) (eq? expr None))\r\n\u001b[?2004l\r"]
[549.288037, "o", "\u001b[?2004h> "]
[549.288069, "o", "          (begin (fclose fid) 'done)\r\n\u001b[?2004l\r"]
[549.288083, "o", "\u001b[?2004h> "]
[549.288124, "o", "          (begin (my-eval expr env) (loop))))))\r\n\u001b[?2004l\r"]
[549.288136, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[549.28815, "o", "\u001b[?2004h> "]
[549.288174, "o", "(eval-file fid global-env)\r\n\u001b[?2004l\r"]
[549.288188, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[549.288201, "o", "\u001b[?2004h> "]
[549.288229, "o", ";; REPL for remaining stdin input\r\n\u001b[?2004l\r"]
[549.288243, "o", "\u001b[?2004h> "]
[549.288256, "o", "(let repl ()\r\n\u001b[?2004l\r"]
[549.28827, "o", "\u001b[?2004h> "]
[549.288289, "o", "  (let ((expr (read)))\r\n\u001b[?2004l\r"]
[549.288301, "o", "\u001b[?2004h> "]
[549.28834, "o", "    (if (or (eq? expr #f) (eq? expr None))\r\n\u001b[?2004l\r"]
[549.288354, "o", "\u001b[?2004h> "]
[549.288368, "o", "        (void)\r\n\u001b[?2004l\r"]
[549.288382, "o", "\u001b[?2004h> "]
[549.288395, "o", "        (begin\r\n\u001b[?2004l\r"]
[549.288409, "o", "\u001b[?2004h> "]
[549.288455, "o", "          (let ((result (my-eval expr global-env)))\r\n\u001b[?2004l\r"]
[549.288467, "o", "\u001b[?2004h> "]
[549.288505, "o", "            (display result) (newline))\r\n\u001b[?2004l\r"]
[549.28852, "o", "\u001b[?2004h> "]
[549.28854, "o", "          (repl)))))\r\n\u001b[?2004l\r"]
[549.288552, "o", "\u001b[?2004h> EOF\r\n"]
[549.288563, "o", "\u001b[?2004l\r"]
[549.289485, "o", "\u001b[?2004h"]
[549.289499, "o", "root@499f5d5c5564:/app# "]
[553.290673, "i", "chmod +x eval.scm\n"]
[553.29098, "o", "chmod +x eval.scm\r\n\u001b[?2004l\r"]
[553.291592, "o", "\u001b[?2004hroot@499f5d5c5564:/app# "]
[553.387339, "i", "echo '(+ 7 8)' | python3 interp.py eval.scm\n"]
[553.387486, "o", "echo '(+ 7 8)' | python3 interp.py eval.scm\r\n"]
[553.387501, "o", "\u001b[?2004l\r"]
[553.400216, "o", "Error: Missing closing parenthesis\r\n"]
[553.402066, "o", "\u001b[?2004h"]
[553.402073, "o", "root@499f5d5c5564:/app# "]
