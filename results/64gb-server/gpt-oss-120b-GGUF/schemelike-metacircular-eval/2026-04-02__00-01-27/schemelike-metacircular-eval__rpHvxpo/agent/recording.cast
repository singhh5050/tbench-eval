[467.599416, "i", "cat > eval.scm <<'EOF'\n;; Metacircular evaluator for interp.py\n\n;; ---------- Environment utilities ----------\n(define global-env '())\n\n(define (make-frame) '())\n(define (frame-extend var val frame) (cons (cons var val) frame))\n(define (frame-lookup var frame)\n  (cond ((null? frame) #f)\n        ((eq? (car (car frame)) var) (cdr (car frame)))\n        (else (frame-lookup var (cdr frame)))))\n\n(define (env-lookup var env)\n  (let loop ((e env))\n    (if (null? e) #f\n        (let ((val (frame-lookup var (car e))))\n          (if val val (loop (cdr e)))))))\n\n(define (env-extend vars vals env)\n  (let ((new-frame (let build ((vs vars) (vs2 vals) (f (make-frame)))\n                     (if (null? vs) f\n                         (build (cdr vs) (cdr vs2) (frame-extend (car vs) (car vs2) f)))))\n    (cons new-frame env)))\n\n(define (env-set! var val env)\n  (let loop ((e env))\n    (if (null? e) (error \"unbound variable\" var)\n        (let ((frame (car e)))\n          (let ((pair (frame-lookup var frame)))\n            (if pair\n   "]
