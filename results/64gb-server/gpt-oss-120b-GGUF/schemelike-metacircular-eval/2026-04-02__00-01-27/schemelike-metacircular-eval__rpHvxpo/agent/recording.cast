[23.248559, "o", "(display \"Reading\")\r\n(newline)\r\n(let ((line (read)))\r\n  (cond\r\n   ((= (car line) '+)\r\n    (display (+ (car (cdr line)) (car (cdr (cdr line))))))\r\n   ((= (car line) '-)\r\n    (display (- (car (cdr line)) (car (cdr (cdr line))))))\r\n   ((= (car line) '*)\r\n    (display (* (car (cdr line)) (car (cdr (cdr line))))))))\r\n(newline)\r\n(display \"Done\")\r\n(newline)\r\n"]
