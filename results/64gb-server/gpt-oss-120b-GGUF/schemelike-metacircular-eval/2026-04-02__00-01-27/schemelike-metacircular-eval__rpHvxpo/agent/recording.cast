[549.281447, "o", "\u001b[?2004h> "]
[549.281481, "i", "n expression type\" exp))))\n\n;; ---------- Procedure application ----------\n(define (my-apply proc args)\n  (cond\n    ((procedure? proc) (apply proc args))\n    ((closure? proc)\n     (let ((new-env (env-extend (closure-params proc) args (closure-env proc))))\n       (my-eval (cons 'begin (closure-body proc)) new-env)))\n    (else (error \"not a procedure\" proc))))\n\n;; ---------- Driver ----------\n;; Read the path of the program file (first line)\n(define file-path (read))\n;; Open the program file for reading\n(define fid (fopen file-path \"r\"))\n\n;; Evaluate each expression from the file\n(define (eval-file fid env)\n  (let loop ()\n    (let ((expr (fread fid)))\n      (if (or (eq? expr #f) (eq? expr None))\n          (begin (fclose fid) 'done)\n          (begin (my-eval expr env) (loop))))))\n\n(eval-file fid global-env)\n\n;; REPL for remaining stdin input\n(let repl ()\n  (let ((expr (read)))\n    (if (or (eq? expr #f) (eq? expr None))\n        (void)\n        (begin\n          (let ((result (my-eval expr global-env)))\n            "]
