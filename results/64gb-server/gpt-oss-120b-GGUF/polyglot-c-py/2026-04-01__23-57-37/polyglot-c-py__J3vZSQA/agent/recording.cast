[66.60543, "i", "cat > /app/polyglot/main.py.c <<'EOF'\n#!/usr/bin/env python3\n#if 0\nimport sys\ndef fib(n):\n    a,b=0,1\n    for _ in range(n):\n        a,b=b,a+b\n    return a\nprint(fib(int(sys.argv[1])))\n#endif\n\n#include <stdio.h>\n#include <stdlib.h>\n\nint main(int argc, char *argv[]) {\n    if (argc < 2) return 0;\n    long n = strtol(argv[1], NULL, 10);\n    long a=0,b=1;\n    for (long i=0;i<n;i++) { long t=a+b; a=b; b=t; }\n    printf(\"%ld\\n\", a);\n    return 0;\n}\nEOF\n"]
