[347.822806, "i", "cat > my_warrior.red <<'EOF'\n;redcode-94\n;name MyWarrior\n;author AI\n;strategy Core‑clear + fast bomber (spl to both threads)\n;assert CORESIZE == 8000 && MAXCYCLES == 80000\n\nstart   spl   clear, bomber   ; launch core‑clear and bomber threads\n        ; no further code needed here\n\nbomber  mov   #0, >0          ; fast moving DAT bomb (drops DAT each step)\n        jmp   bomber\n\n;--- core‑clear (G2‑Clear) ---\n\ndec     equ     2700                ; decrement value for bomb counter\ngate    equ     clear-4             ; gate location relative to clear\n\n        org     clear-1             ; start just before clear loop\n\nbptr    dat     bombc,       9      ; pointer to bomb for clear loop\nbombc   spl     #dec,       11      ; split creates many processes\nclear   mov     *bptr,      >gate   ; move bomb contents through gate pointer\n        mov     *bptr,      >gate   ; second move for double clearing\n        djn.f   clear,      }bombc  ; decrement and jump if not zero (loop control)\n\n        end     start\nEOF\n"]
[347.823087, "o", "cat > my_warrior.red <<'EOF'\r\n\u001b[?2004l\r"]
