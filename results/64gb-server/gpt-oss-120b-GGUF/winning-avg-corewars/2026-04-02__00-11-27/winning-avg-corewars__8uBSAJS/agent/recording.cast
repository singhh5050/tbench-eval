[298.626764, "i", "cat > my_warrior.red <<'EOF'\n;redcode-94\n;name MyWarrior\n;author AI\n;strategy Core‑clear with four early SPLs and a fast moving bomb\n;assert CORESIZE == 8000 && MAXCYCLES == 80000\n\nstart   spl   1, >0          ; first extra process\n        spl   1, >0          ; second extra process\n        spl   1, >0          ; third extra process\n        spl   1, >0          ; fourth extra process\n        mov   #0, >0         ; fast moving DAT bomb\n        jmp   clear          ; jump into clear loop\n\n;--- core‑clear (G2‑Clear) ---\n\ndec     equ     2700                ; Decrement value for bomb counter\ngate    equ     clear-4             ; Gate location relative to clear\n\n        org     clear-1             ; start just before clear\n\nbptr    dat     bomb,       9       ; pointer to bomb with offset 9\nbomb    spl     #dec,       11      ; split with decrement value, creates processes\nclear   mov     *bptr,      >gate   ; move bomb contents through gate pointer\n        mov     *bptr,      >gate   ; second move for double clearing\n        djn.f   clear,      }bomb   ; decrement and jump if not zero (loop control)\n\n        end\nEOF\n"]
[298.627089, "o", "cat > my_warrior.red <<'EOF'\r\n\u001b[?2004l\r\u001b[?2004h> "]
