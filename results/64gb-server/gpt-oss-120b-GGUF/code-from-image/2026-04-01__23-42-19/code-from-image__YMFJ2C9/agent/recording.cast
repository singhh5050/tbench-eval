[445.339152, "i", "cat > /app/brute.py << 'EOF'\nimport hashlib, pathlib\n\ndata = pathlib.Path('/app/code.png').read_bytes()\ninitial = hashlib.sha256(data).digest()\n\ncandidates = [\n    b'60000TBENCH-SALT',\n    b'60000BENCH-SALT',\n    b'60000TBENCH-SALT\"',\n    b'\"60000TBENCH-SALT\"',\n    b'6\"0000TBENCH-SALT',\n    b'6\"0000TBENCH-SALT\"',\n    b'60000TBENCH-SALT\\n',\n    b'60000TBENCH-SALT\\r',\n]\n\nfor salt in candidates:\n    for it in range(5, 16):\n        h = initial\n        for _ in range(it):\n            h = hashlib.sha256(h + salt).digest()\n        prefix = h.hex()[:6]\n        if prefix.startswith('bee26a'):\n            print('FOUND', salt, 'iters', it, 'hash', h.hex())\n        else:\n            print('TRY', salt, 'iters', it, 'prefix', prefix)\nEOF\n"]
