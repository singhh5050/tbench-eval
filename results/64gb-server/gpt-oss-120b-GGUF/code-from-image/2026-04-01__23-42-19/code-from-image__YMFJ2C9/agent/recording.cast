[399.100979, "i", "cat > /app/solution.py << 'EOF'\nimport hashlib, pathlib\n\ndef main():\n    data = pathlib.Path('/app/code.png').read_bytes()\n    # Initial binary digest\n    h = hashlib.sha256(data).digest()\n    salt = b'60000TBENCH-SALT'\n    for _ in range(10):\n        # Convert previous digest to hex string, concatenate with salt, hash again (binary result)\n        h = hashlib.sha256((h.hex().encode()) + salt).digest()\n    print(h.hex())\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
