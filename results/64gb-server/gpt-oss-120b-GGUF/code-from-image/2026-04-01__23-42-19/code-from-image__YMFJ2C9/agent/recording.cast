[267.052943, "i", "cat > /app/solution.py << 'EOF'\nimport hashlib, pathlib\n\ndef main():\n    data = pathlib.Path('/app/code.png').read_bytes()\n    # Initial hash as hex string\n    h = hashlib.sha256(data).hexdigest()\n    salt = '60000TBENCH-SALT'\n    for _ in range(10):\n        h = hashlib.sha256((h + salt).encode()).hexdigest()\n    print(h)\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
