[514.8129, "i", "cat > /app/solution.py << 'EOF'\nimport hashlib, pathlib\n\ndef main():\n    data = pathlib.Path('/app/code.png').read_bytes()\n    # First SHA-256 digest of the file\n    ho = hashlib.sha256(data).digest()\n    # Take first 10 bytes (as hinted by 'hof:10]')\n    part = ho[:10]\n    salt = b'60000TBENCH-SALT'\n    final = hashlib.sha256(part + salt).hexdigest()\n    print(final)\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
