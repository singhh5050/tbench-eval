[175.846286, "i", "cat > /app/solution.py << 'EOF'\nimport hashlib, pathlib\n\ndef main():\n    data = pathlib.Path('/app/code.png').read_bytes()\n    # Initial hash (binary digest)\n    h = hashlib.sha256(data).digest()\n    salt = b'60000TBENCH-SALT'\n    # Perform 10 iterations of hashing h + salt\n    for _ in range(10):\n        h = hashlib.sha256(h + salt).digest()\n    print(h.hex())\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
