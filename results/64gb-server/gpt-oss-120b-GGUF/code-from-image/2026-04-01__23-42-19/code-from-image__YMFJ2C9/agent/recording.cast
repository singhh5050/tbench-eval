[543.839265, "i", "cat > /app/solution.py << 'EOF'\nimport hashlib, pathlib\n\ndef compute(salt_str):\n    data = pathlib.Path('/app/code.png').read_bytes()\n    ho_hex = hashlib.sha256(data).hexdigest()\n    part = ho_hex[:10]\n    return hashlib.sha256((part + salt_str).encode()).hexdigest()\n\ndef main():\n    # primary salt inferred from OCR\n    result = compute('60000TBENCH-SALT')\n    print(result)\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
