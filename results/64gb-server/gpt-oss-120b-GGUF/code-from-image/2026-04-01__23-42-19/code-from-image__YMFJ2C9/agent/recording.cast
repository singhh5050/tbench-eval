[587.546536, "i", "cat > /app/solution.py << 'EOF'\nimport hashlib, pathlib\n\ndef compute(salt_bytes, prepend=False):\n    data = pathlib.Path('/app/code.png').read_bytes()\n    ho = hashlib.sha256(data).digest()\n    part = ho[:10]\n    if prepend:\n        payload = salt_bytes + part\n    else:\n        payload = part + salt_bytes\n    return hashlib.sha256(payload).hexdigest()\n\ndef main():\n    # primary salt inferred from OCR\n    salt = b'60000TBENCH-SALT'\n    result = compute(salt, prepend=False)\n    print(result)\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
