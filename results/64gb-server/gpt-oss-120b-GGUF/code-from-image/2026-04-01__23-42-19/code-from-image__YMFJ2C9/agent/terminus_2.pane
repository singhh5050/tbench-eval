[?2004ldef main():
GALT = 6"0000TBENCH-SALT”

img_ bytes = read_file_ bytes( ‘Tapp/code.png’)
hO = cha256(img_ bytes)

# cha2z56(ho // hof-t0] |/ SALT)
H = cha256(ho, hof:10], SALT)

print(H.bex())

return
[?2004hroot@6c9fdc47807a:/app# cat > /app/solution.py << 'EOF'
[?2004l[?2004h> import hashlib, pathlib
[?2004l[?2004h> 
[?2004l[?2004h> def main():
[?2004l[?2004h>     data = pathlib.Path('/app/code.png').read_bytes()
[?2004l[?2004h>     # First hash of the file bytes
[?2004l[?2004h>     h1 = hashlib.sha256(data).hexdigest()
[?2004l[?2004h>     # Salt as inferred from OCR (adjust if needed)
[?2004l[?2004h>     salt = '60000BENCH-SALT'
[?2004l[?2004h>     # Second hash of the concatenation of first hash and salt
[?2004l[?2004h>     h2 = hashlib.sha256((h1 + salt).encode()).hexdigest()
[?2004l[?2004h>     print(h2)
[?2004l[?2004h> 
[?2004l[?2004h> if __name__ == '__main__':
