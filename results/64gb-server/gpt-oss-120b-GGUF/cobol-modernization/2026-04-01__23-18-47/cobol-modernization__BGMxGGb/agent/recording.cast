[86.583796, "i", "cat > /app/program.py <<'PY'\n#!/usr/bin/env python3\nimport sys\n\n# Fixed widths\nACC_ID_W = 4\nACC_NAME_W = 20\nACC_BAL_W = 10\nBOOK_ID_W = 4\nBOOK_TITLE_W = 20\nBOOK_OWNER_W = 4\nTRANS_BOOK_W = 4\nTRANS_AMT_W = 10\nTRANS_SELLER_W = 4\nTRANS_BUYER_W = 4\n\ndef read_fixed_records(path, rec_len):\n    data = open(path, 'r').read()\n    return [data[i:i+rec_len] for i in range(0, len(data), rec_len) if len(data[i:i+rec_len]) == rec_len]\n\ndef parse_accounts(records):\n    accounts = []\n    for rec in records:\n        acct_id = rec[0:ACC_ID_W]\n        name = rec[ACC_ID_W:ACC_ID_W+ACC_NAME_W]\n        balance = int(rec[ACC_ID_W+ACC_NAME_W:ACC_ID_W+ACC_NAME_W+ACC_BAL_W])\n        accounts.append([acct_id, name, balance])\n    return accounts\n\ndef serialize_accounts(accounts):\n    out = []\n    for acct_id, name, balance in accounts:\n        out.append(\n            f\"{acct_id}\" +\n            f\"{name}\" +\n            f\"{balance:0{ACC_BAL_W}d}\"\n        )\n    return ''.join(out)\n\ndef parse_books(records):\n    books = []\n    for rec in recor"]
[86.584036, "o", "cat > /app/program.py <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> #!/usr/bin/env python3\r\n\u001b[?2004l\r\u001b[?2004h> import sys\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[86.584064, "i", "ds:\n        book_id = rec[0:BOOK_ID_W]\n        title = rec[BOOK_ID_W:BOOK_ID_W+BOOK_TITLE_W]\n        owner = rec[BOOK_ID_W+BOOK_TITLE_W:BOOK_ID_W+BOOK_TITLE_W+BOOK_OWNER_W]\n        books.append([book_id, title, owner])\n    return books\n\ndef serialize_books(books):\n    out = []\n    for book_id, title, owner in books:\n        out.append(f\"{book_id}{title}{owner}\")\n    return ''.join(out)\n\ndef parse_transactions(records):\n    trans = []\n    for rec in records:\n        book = rec[0:TRANS_BOOK_W]\n        amt = int(rec[TRANS_BOOK_W:TRANS_BOOK_W+TRANS_AMT_W])\n        seller = rec[TRANS_BOOK_W+TRANS_AMT_W:TRANS_BOOK_W+TRANS_AMT_W+TRANS_SELLER_W]\n        buyer = rec[TRANS_BOOK_W+TRANS_AMT_W+TRANS_SELLER_W:]\n        trans.append([book, amt, seller, buyer])\n    return trans\n\ndef serialize_transaction(book, amt, seller, buyer):\n    return f\"{book}{amt:0{TRANS_AMT_W}d}{seller}{buyer}\"\n\n# --- Main processing ---\n# Read INPUT.DAT (single record)\ninput_data = open('src/INPUT.DAT', 'r').read().strip()\nif len(input_data) < 12:"]
[86.584109, "o", "# Fixed widths\r\n\u001b[?2004l\r\u001b[?2004h> ACC_ID_W = 4\r\n\u001b[?2004l\r\u001b[?2004h> ACC_NAME_W = 20\r\n\u001b[?2004l\r\u001b[?2004h> "]
[86.584123, "i", "\n    print('Error: Input file is empty')\n    sys.exit(1)\nbuyer_id = input_data[0:4]\nseller_id = input_data[4:8]\nbook_id = input_data[8:12]\namount_str = input_data[12:]\n# amount may be shorter than 10 digits; treat missing leading zeros as zeros\namount = int(amount_str) if amount_str else 0\n\n# Load data files\naccount_records = read_fixed_records('data/ACCOUNTS.DAT', ACC_ID_W+ACC_NAME_W+ACC_BAL_W)\naccounts = parse_accounts(account_records)\nbook_records = read_fixed_records('data/BOOKS.DAT', BOOK_ID_W+BOOK_TITLE_W+BOOK_OWNER_W)\nbooks = parse_books(book_records)\ntrans_records = read_fixed_records('data/TRANSACTIONS.DAT', TRANS_BOOK_W+TRANS_AMT_W+TRANS_SELLER_W+TRANS_BUYER_W)\ntransactions = parse_transactions(trans_records)\n\n# Validation flags\nbuyer_found = any(acct_id == buyer_id for acct_id, _, _ in accounts)\nseller_found = any(acct_id == seller_id for acct_id, _, _ in accounts)\nbook_entry = next((b for b in books if b[0] == book_id), None)\nbook_found = book_entry is not None\nvalid_owner = book_found and (book_e"]
[86.58414, "o", "ACC_BAL_W = 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[86.584152, "i", "ntry[2] == seller_id)\n\nif buyer_found and seller_found and book_found and valid_owner:\n    # Process transaction: update balances\n    for acct in accounts:\n        if acct[0] == buyer_id:\n            acct[2] -= amount\n        if acct[0] == seller_id:\n            acct[2] += amount\n    # Update book owner\n    for b in books:\n        if b[0] == book_id:\n            b[2] = buyer_id\n    # Append transaction record\n    new_trans = serialize_transaction(book_id, amount, seller_id, buyer_id)\n    transactions.append([book_id, amount, seller_id, buyer_id])\n    # Write back files\n    open('data/ACCOUNTS.DAT', 'w').write(serialize_accounts(accounts))\n    open('data/BOOKS.DAT', 'w').write(serialize_books(books))\n    # Append to transactions file preserving existing content\n    with open('data/TRANSACTIONS.DAT', 'a') as f:\n        f.write(new_trans)\n    print('Transaction completed successfully')\nelse:\n    print('Transaction failed due to validation errors')\nPY\n"]
