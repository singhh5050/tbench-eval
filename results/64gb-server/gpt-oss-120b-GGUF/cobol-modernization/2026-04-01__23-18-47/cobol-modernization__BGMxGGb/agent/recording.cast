[86.586145, "o", "    for rec in records:\r\n\u001b[?2004l\r"]
[86.586164, "o", "\u001b[?2004h> "]
[86.586196, "o", "        book = rec[0:TRANS_BOOK_W]\r\n\u001b[?2004l\r\u001b[?2004h"]
[86.586226, "o", "> "]
[86.586295, "o", "        amt = int(rec[TRANS_BOOK_W:TRANS_BOOK_W+TRANS_AMT_W])\r\n\u001b[?2004l\r"]
[86.586332, "o", "\u001b[?2004h> "]
[86.58637, "o", "        seller = rec[TRANS_BOOK_W+TRANS_AMT_W:TRANS_BOOK_W+TRANS_AMT_W+TRANS_SELLER_W]\r\n\u001b[?2004l\r\u001b[?2004h"]
[86.586384, "o", "> "]
[86.586443, "o", "        buyer = rec[TRANS_BOOK_W+TRANS_AMT_W+TRANS_SELLER_W:]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[86.586494, "o", "        trans.append([book, amt, seller, buyer])\r\n\u001b[?2004l\r\u001b[?2004h"]
[86.58651, "o", "> "]
[86.586525, "o", "    return trans\r\n\u001b[?2004l\r\u001b[?2004h"]
[86.58654, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[86.58659, "o", "def serialize_transaction(book, amt, seller, buyer):\r\n\u001b[?2004l\r"]
[86.586605, "o", "\u001b[?2004h> "]
[86.586657, "o", "    return f\"{book}{amt:0{TRANS_AMT_W}d}{seller}{buyer}\"\r\n\u001b[?2004l\r"]
[86.586673, "o", "\u001b[?2004h> \r\n"]
[86.586688, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[86.586713, "o", "# --- Main processing ---\r\n\u001b[?2004l\r"]
[86.586726, "o", "\u001b[?2004h> "]
[86.58676, "o", "# Read INPUT.DAT (single record)\r\n\u001b[?2004l\r"]
[86.586774, "o", "\u001b[?2004h> "]
[86.586826, "o", "input_data = open('src/INPUT.DAT', 'r').read().strip()\r\n\u001b[?2004l\r"]
[86.58684, "o", "\u001b[?2004h> "]
[86.586864, "o", "if len(input_data) < 12:\r\n\u001b[?2004l\r"]
[86.586879, "o", "\u001b[?2004h> "]
[86.586926, "o", "    print('Error: Input file is empty')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[86.586945, "o", "    sys.exit(1)\r\n\u001b[?2004l\r"]
[86.586959, "o", "\u001b[?2004h> "]
[86.586999, "o", "buyer_id = input_data[0:4]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[86.587028, "o", "seller_id = input_data[4:8]\r\n\u001b[?2004l\r"]
[86.587046, "o", "\u001b[?2004h> "]
[86.587069, "o", "book_id = input_data[8:12]\r\n\u001b[?2004l\r"]
[86.587081, "o", "\u001b[?2004h> "]
[86.587116, "o", "amount_str = input_data[12:]\r\n\u001b[?2004l\r"]
[86.587129, "o", "\u001b[?2004h> "]
[86.587198, "o", "# amount may be shorter than 10 digits; treat missing leading zeros as zeros\r\n\u001b[?2004l\r"]
[86.587213, "o", "\u001b[?2004h> "]
[86.587256, "o", "amount = int(amount_str) if amount_str else 0\r\n\u001b[?2004l\r"]
[86.58727, "o", "\u001b[?2004h"]
[86.587286, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[86.587304, "o", "# Load data files\r\n\u001b[?2004l\r"]
[86.587318, "o", "\u001b[?2004h> "]
[86.587397, "o", "account_records = read_fixed_records('data/ACCOUNTS.DAT', ACC_ID_W+ACC_NAME_W+ACC_BAL_W)\r\n\u001b[?2004l\r"]
[86.587413, "o", "\u001b[?2004h> "]
[86.587471, "o", "accounts = parse_accounts(account_records)\r\n\u001b[?2004l\r"]
[86.587485, "o", "\u001b[?2004h> "]
[86.587563, "o", "book_records = read_fixed_records('data/BOOKS.DAT', BOOK_ID_W+BOOK_TITLE_W+BOOK_OWNER_W)\r\n\u001b[?2004l\r"]
[86.587576, "o", "\u001b[?2004h> "]
[86.587607, "o", "books = parse_books(book_records)\r\n\u001b[?2004l\r"]
[86.587619, "o", "\u001b[?2004h> "]
[86.587717, "o", "trans_records = read_fixed_records('data/TRANSACTIONS.DAT', TRANS_BOOK_W+TRANS_AMT_W+TRANS_SELLER_W+TRANS_BUYER_W)\r\n\u001b[?2004l\r"]
[86.58773, "o", "\u001b[?2004h> "]
[86.587774, "o", "transactions = parse_transactions(trans_records)\r\n\u001b[?2004l\r"]
[86.587786, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[86.587798, "o", "\u001b[?2004h> "]
[86.587816, "o", "# Validation flags\r\n\u001b[?2004l\r"]
[86.587829, "o", "\u001b[?2004h> "]
[86.587889, "o", "buyer_found = any(acct_id == buyer_id for acct_id, _, _ in accounts)\r\n\u001b[?2004l\r"]
[86.587906, "o", "\u001b[?2004h> "]
[86.58797, "o", "seller_found = any(acct_id == seller_id for acct_id, _, _ in accounts)\r\n\u001b[?2004l\r"]
[86.587982, "o", "\u001b[?2004h> "]
[86.588037, "o", "book_entry = next((b for b in books if b[0] == book_id), None)\r\n\u001b[?2004l\r"]
[86.588048, "o", "\u001b[?2004h> "]
[86.588081, "o", "book_found = book_entry is not None\r\n\u001b[?2004l\r"]
[86.588092, "o", "\u001b[?2004h> "]
[86.588146, "o", "valid_owner = book_found and (book_entry[2] == seller_id)\r\n\u001b[?2004l\r"]
[86.588158, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[86.588169, "o", "\u001b[?2004h> "]
[86.588226, "o", "if buyer_found and seller_found and book_found and valid_owner:\r\n\u001b[?2004l\r"]
[86.58824, "o", "\u001b[?2004h> "]
[86.588278, "o", "    # Process transaction: update balances\r\n\u001b[?2004l\r"]
[86.58829, "o", "\u001b[?2004h> "]
[86.588315, "o", "    for acct in accounts:\r\n\u001b[?2004l\r"]
[86.588327, "o", "\u001b[?2004h> "]
[86.588357, "o", "        if acct[0] == buyer_id:\r\n\u001b[?2004l\r"]
[86.588369, "o", "\u001b[?2004h> "]
[86.588396, "o", "            acct[2] -= amount\r\n\u001b[?2004l\r"]
[86.588408, "o", "\u001b[?2004h> "]
[86.588438, "o", "        if acct[0] == seller_id:\r\n\u001b[?2004l\r"]
[86.58845, "o", "\u001b[?2004h> "]
[86.588477, "o", "            acct[2] += amount\r\n\u001b[?2004l\r"]
[86.58849, "o", "\u001b[?2004h> "]
[86.588511, "o", "    # Update book owner\r\n\u001b[?2004l\r"]
[86.588523, "o", "\u001b[?2004h> "]
[86.588542, "o", "    for b in books:\r\n\u001b[?2004l\r"]
[86.588554, "o", "\u001b[?2004h> "]
[86.58858, "o", "        if b[0] == book_id:\r\n\u001b[?2004l\r"]
[86.588593, "o", "\u001b[?2004h> "]
[86.588618, "o", "            b[2] = buyer_id\r\n\u001b[?2004l\r"]
[86.588629, "o", "\u001b[?2004h> "]
[86.588659, "o", "    # Append transaction record\r\n\u001b[?2004l\r"]
[86.588671, "o", "\u001b[?2004h> "]
[86.588737, "o", "    new_trans = serialize_transaction(book_id, amount, seller_id, buyer_id)\r\n\u001b[?2004l\r"]
[86.58875, "o", "\u001b[?2004h> "]
[86.588806, "o", "    transactions.append([book_id, amount, seller_id, buyer_id])\r\n\u001b[?2004l\r"]
[86.588819, "o", "\u001b[?2004h> "]
[86.58884, "o", "    # Write back files\r\n\u001b[?2004l\r"]
[86.588853, "o", "\u001b[?2004h> "]
[86.588918, "o", "    open('data/ACCOUNTS.DAT', 'w').write(serialize_accounts(accounts))\r\n\u001b[?2004l\r"]
[86.58893, "o", "\u001b[?2004h> "]
[86.588985, "o", "    open('data/BOOKS.DAT', 'w').write(serialize_books(books))\r\n\u001b[?2004l\r"]
[86.588998, "o", "\u001b[?2004h> "]
[86.589052, "o", "    # Append to transactions file preserving existing content\r\n\u001b[?2004l\r"]
[86.589065, "o", "\u001b[?2004h> "]
[86.589108, "o", "    with open('data/TRANSACTIONS.DAT', 'a') as f:\r\n\u001b[?2004l\r"]
[86.58912, "o", "\u001b[?2004h> "]
[86.589146, "o", "        f.write(new_trans)\r\n\u001b[?2004l\r"]
[86.589159, "o", "\u001b[?2004h> "]
[86.589204, "o", "    print('Transaction completed successfully')\r\n\u001b[?2004l\r"]
[86.589215, "o", "\u001b[?2004h> "]
[86.589228, "o", "else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[86.589239, "o", "> "]
[86.589288, "o", "    print('Transaction failed due to validation errors')\r\n\u001b[?2004l\r"]
[86.5893, "o", "\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
[86.590661, "o", "\u001b[?2004hroot@34cde06ed11c:/app# "]
