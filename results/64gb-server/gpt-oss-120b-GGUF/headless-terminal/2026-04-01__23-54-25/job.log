not keystrokes:\n            # Nothing to send – just wait if requested.\n            if wait_sec:\n                time.sleep(wait_sec)\n            return\n\n        # Send the keystrokes directly to the pexpect child.\n        self._process.send(keystrokes)\n        # Flush any pending output by briefly waiting; the caller can specify a\n        # longer wait if the command is expected to take more time.\n        if wait_sec:\n            time.sleep(wait_sec)\n        else:\n            # A very short pause helps interactive programs process the input.\n            time.sleep(0.01)\n\n    def __del__(self):\n        # Ensure the child process is terminated when the object is garbage\n        # collected.\n        if hasattr(self, \'_process\') and self._process.isalive():\n            self._process.terminate(force=True)\nEOF\n'] min_timeout_sec: 0.5 max_timeout_sec: 180.0
