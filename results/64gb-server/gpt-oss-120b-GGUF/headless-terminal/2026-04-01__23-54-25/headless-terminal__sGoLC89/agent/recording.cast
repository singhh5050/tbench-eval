[55.944012, "i", "python - <<'PY'\nimport sys, time\nsys.path.append('.')\nfrom headless_terminal import HeadlessTerminal\nterm = HeadlessTerminal()\nterm.send_keystrokes('echo hello_world\\n', wait_sec=0.2)\n# Give the process a moment to flush output\ntime.sleep(0.1)\n# Read any available output\noutput = term._process.read_nonblocking(size=1024, timeout=1)\nprint('OUTPUT:', output.strip())\nPY\n"]
