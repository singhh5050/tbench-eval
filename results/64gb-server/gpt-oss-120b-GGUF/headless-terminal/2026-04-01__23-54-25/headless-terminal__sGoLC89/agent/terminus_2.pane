[?2004l[?2004h> 
[?2004l[?2004h> class BaseTerminal(ABC):
[?2004l[?2004h>     @abstractmethod
[?2004l[?2004h>     def send_keystrokes(self, keystrokes: str, wait_sec: float = 0.0) -> None:
[?2004l[?2004h>         """
[?2004l[?2004h>         Sends keystrokes to the terminal.
[?2004l[?2004h> 
[?2004l[?2004h>         Args:
[?2004l[?2004h>             keystrokes: The keystrokes to send to the terminal.
[?2004l[?2004h>             wait_sec: The number of seconds to wait for the command to complete.
[?2004l[?2004h>         """
[?2004l[?2004h>         pass
[?2004l[?2004h> 
[?2004l[?2004h> class HeadlessTerminal(BaseTerminal):
[?2004l[?2004h>     """Concrete implementation of BaseTerminal using an interactive bash shell.
[?2004l[?2004h> 
[?2004l[?2004h>     This class spawns an interactive bash process (so that ~/.bashrc and other
[?2004l[?2004h>     startup files are sourced) and provides a `send_keystrokes` method that
[?2004l[?2004h>     writes characters (including control sequences) to the process' stdin.
[?2004l[?2004h>     """
[?2004l[?2004h> 
[?2004l[?2004h>     def __init__(self):
[?2004l[?2004h>         # Start an interactive bash shell. The '-i' flag ensures that startup
[?2004l[?2004h>         # files such as ~/.bashrc are sourced.
[?2004l[?2004h>         self._process = pexpect.spawn('/bin/bash', ['-i'], encoding='utf-8', echo=False)
[?2004l[?2004h>         # Wait for the initial prompt. Bash typically ends prompts with '$' for
[?2004l[?2004h>         # normal users or '#' for root. The regex is deliberately permissive.
[?2004l[?2004h>         try:
[?2004l[?2004h>             self._process.expect(r'[#$] ', timeout=5)
[?2004l[?2004h>         except pexpect.exceptions.TIMEOUT:
[?2004l[?2004h>             # If we cannot detect a prompt, continue; the shell is likely ready.
[?2004l[?2004h>             pass
[?2004l[?2004h> 
[?2004l[?2004h>     def send_keystrokes(self, keystrokes: str, wait_sec: float = 0.0) -> None:
[?2004l[?2004h>         """Send keystrokes to the interactive bash process.
[?2004l[?2004h> 
[?2004l[?2004h>         Parameters
[?2004l[?2004h>         ----------
[?2004l[?2004h>         keystrokes: str
[?2004l[?2004h>             The characters to send. This may include newline characters to
[?2004l[?2004h>             execute commands and control characters (e.g., "\x03" for Ctrl‑C).
[?2004l[?2004h>         wait_sec: float, optional
[?2004l[?2004h>             Seconds to wait after sending the keystrokes. Defaults to ``0.0``.
[?2004l[?2004h>         """
[?2004l[?2004h>         if not keystrokes:
[?2004l[?2004h>             # Nothing to send – just wait if requested.
[?2004l[?2004h>             if wait_sec:
[?2004l[?2004h>                 time.sleep(wait_sec)
[?2004l[?2004h>             return
[?2004l[?2004h> 
[?2004l[?2004h>         # Send the keystrokes directly to the pexpect child.
[?2004l[?2004h>         self._process.send(keystrokes)
[?2004l[?2004h>         # Flush any pending output by briefly waiting; the caller can specify a
[?2004l[?2004h>         # longer wait if the command is expected to take more time.
[?2004l[?2004h>         if wait_sec:
[?2004l[?2004h>             time.sleep(wait_sec)
[?2004l[?2004h>         else:
[?2004l[?2004h>             # A very short pause helps interactive programs process the input.
[?2004l[?2004h>             time.sleep(0.01)
[?2004l[?2004h> 
[?2004l[?2004h>     def __del__(self):
[?2004l[?2004h>         # Ensure the child process is terminated when the object is garbage
[?2004l[?2004h>         # collected.
[?2004l[?2004h>         if hasattr(self, '_process') and self._process.isalive():
[?2004l[?2004h>             self._process.terminate(force=True)
[?2004l[?2004h> EOF
