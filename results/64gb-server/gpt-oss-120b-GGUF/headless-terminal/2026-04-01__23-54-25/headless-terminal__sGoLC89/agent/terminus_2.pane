[?2004l[?2004h> sys.path.append('.')
[?2004l[?2004h> from headless_terminal import HeadlessTerminal
[?2004l[?2004h> term = HeadlessTerminal()
[?2004l[?2004h> term.send_keystrokes('echo hello_world\n', wait_sec=0.2)
[?2004l[?2004h> # Give the process a moment to flush output
[?2004l[?2004h> time.sleep(0.1)
